  });
};

for (let file of req.files) {
    const uploadResult = await streamUpload(file.buffer);
    uploadedImages[file.originalname] = uploadResult.secure_url;
}
parsedVariants.forEach((variant) => {
  variant.images = variant.images.map(img => ({
    originalUrl: uploadedImages[img.originalFileName],
    croppedUrl: img.croppedFileName ? uploadedImages[img.croppedFileName] : null 
  }));
});

const newProduct = new Product({
  product,
