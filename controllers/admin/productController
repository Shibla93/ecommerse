const createProduct = async (req, res) => {
  try {
    
    const { product, brand, description, strapMaterial,  productOffer } = req.body;
    

    

    
    const category = req.body.category
let parsedVariants = [];
try {
    parsedVariants = req.body.variants ? JSON.parse(req.body.variants) : [];
    console.log("FILES:", req.files); 

} catch (e) {
    return res.status(StatusCodes.BAD_REQUEST).json({ success:false, message: "Invalid variants format" });
}

if (!parsedVariants.length) {
    return res.status(StatusCodes.BAD_REQUEST).json({ success:false, message: Messages.VARIENT_REQUIRED });
}



    if (!product || product.trim().length < 3){
        return res.status(StatusCodes.BAD_REQUEST).json({ success:false,message:Messages.PRODUCT_NAME_VALID  });
    } 
     
       const trimmedName = product.trim().toLowerCase();
    const existingProduct = await Product.findOne({ product: { $regex: `^${trimmedName}$`, $options: "i" } });


        if (existingProduct) {
            return res.json({ success:false, message:Messages.PRODUCT_EXIST });
        }

    
    if (!brand||!strapMaterial){
       return res.status(StatusCodes.BAD_REQUEST).json({success:false,message:Messages.PRODUCT_BRAND_STRAPE });
    }
    
   if (!category) {
 return res.status(StatusCodes.BAD_REQUEST).json({
   success:false,
   message:"Category is required"
 })
}

  

// Validate productOffer
const productOfferVal = Number(productOffer);
if (isNaN(productOfferVal) || productOfferVal < 0 || productOfferVal > 100) {
    return res.status(StatusCodes.BAD_REQUEST).json({
        success: false,
        message: "Product Offer must be a number between 0 and 100"
    });
}
    if (!parsedVariants || parsedVariants.length === 0){
     return res.status(StatusCodes.BAD_REQUEST).json({success:false,message:Messages.VARIENT_REQUIRED })
    } ;
   for (let i = 0; i < parsedVariants.length; i++) {
    const v = parsedVariants[i];  
    if (!v.dialColor || !v.strapColor) {
        return res.status(StatusCodes.BAD_REQUEST).json({ error: `Variant ${i + 1}: Dial and Strap color required` });
    }
    if (!v.price || v.price <= 0) {
