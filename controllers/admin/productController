});

await newProduct.save();
res.json({ success: true,message:Messages.PRODUCT_ADDED, product: newProduct });

  } catch (err) {
    console.error(err);
    return res.status(StatusCodes.INTERNAL_SERVER_ERROR).json({ success: false, message: Messages.INTERNAL_SERVER_ERROR });
  }
}

const getProduct = async (req, res) => {
  try {
    
    
      const search = (req.query.search || "").trim();
    const page = parseInt(req.query.page) || 1;
    const limit = 3;
    const skip = (page - 1) * limit;

    // 🔹 Build search match stage
    const matchStage = {
      "variants.isDeleted": false
    };
    if (search) {
      matchStage.product = { $regex: search, $options: "i" };
    }

    // 🔹 Count total products with non-deleted variants
    const totalProductsArr = await Product.aggregate([
      { $unwind: "$variants" },
      { $match: matchStage },
      { $group: { _id: "$_id" } } // unique products
    ]);

    const totalProducts = totalProductsArr.length;
    const totalPages = Math.ceil(totalProducts / limit);

  

    const products = await Product.aggregate([
  { $unwind: "$variants" },
  { $match: { "variants.isDeleted": false } },
  { $group: {
      _id: "$_id",
      product: { $first: "$product" },
      brand: { $first: "$brand" },
      description: { $first: "$description" },
      strapMaterial: { $first: "$strapMaterial" },
      discount: { $first: "$discount" },
      categories: { $first: "$categories" },
      variants: { $push: "$variants" },
      productOffer: { $first: "$productOffer" },
      createdAt: { $first: "$createdAt" },
      updatedAt: { $first: "$updatedAt" }
  }},
  { $sort: { createdAt: -1 } },
  { $skip: skip },
  { $limit: limit }
]);
         

    res.render("admin/product", { products, search,
      currentPage: page,
      totalPages }); 
  } catch (err) {
    console.error(err);
    return res.status(StatusCodes.INTERNAL_SERVER_ERROR).json({ success: false, message: Messages.INTERNAL_SERVER_ERROR });
  }
};


