const deleteProduct=async(req,res)=>{
  try {
  
    const { id: productId, variantId } = req.params;

    
    const product = await Product.findById(productId);
    if (!product) {
      return res.status(StatusCodes.NOT_FOUND).json({ success: false, message: Messages.PRODUCT_NOT_FOUND });
    }

    // Find the variant
    const variant = product.variants.id(variantId);
    if (!variant) {
      return res.status(StatusCodes.NOT_FOUND).json({ success: false, message: Messages.VARIANT_NOTFOUD });
    }

    //
    variant.isDeleted = true;

    await product.save();

    return res.json({
      success: true,
      message: `Variant ${variant.dialColor} - ${variant.strapColor}  deleted`,
    })
  } catch (error) {
    console.log(error)
    return res.status(StatusCodes.INTERNAL_SERVER_ERROR).json({ success: false, message: Messages.INTERNAL_SERVER_ERROR });
  }
}


