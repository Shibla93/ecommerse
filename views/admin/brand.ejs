<%- include("../../views/partials/admin/header") %>
<style>
  :root {
    --color-gold: #d4af37;
    --color-gold-hover: #c19a2e;
    --color-dark: #1a1a1a;
    --color-muted: #6b7280;
    --color-border: #e5e7eb;
    --color-card-bg: #ffffff;
    --color-light-bg: #f9fafb;
    --radius-lg: 1rem;
    --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.1);
    --shadow-lg: 0 10px 15px -3px rgba(0,0,0,0.1);
  }

  body {
    font-family: 'Montserrat', sans-serif;
    background: var(--color-light-bg);
    min-height: 100vh;
  }

  .container {
    max-width: 1400px;
    margin: 120px auto 80px; /* Clears fixed header + space for footer */
    padding: 0 20px;
  }
.pagination .page-link {
  color: #d4af37;
  border-radius: 8px;
}

.pagination .active .page-link {
  background-color: #d4af37;
  border-color: #d4af37;
  color: white;
}
  .page-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-dark);
    text-align: center;
    margin-bottom: 2.5rem;
    border-bottom: 2px solid var(--color-gold);
    display: inline-block;
    padding-bottom: 0.5rem;
  }

  .header-with-btn {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .add-btn {
    padding: 0.7rem 1.5rem;
    background: #22c55e;
    color: white;
    border: none;
    border-radius: 0.75rem;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .add-btn:hover {
    background: #16a34a;
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .table-wrapper {
    background: var(--color-card-bg);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }

  .search-bar {
    margin-bottom: 2rem;
    display: flex;
    justify-content: flex-end;
  }

  .search-bar .position-relative {
    position: relative;
    width: 300px;
  }

  .search-bar input {
    width: 100%;
    padding: 0.8rem 1rem 0.8rem 2.5rem;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    font-size: 1rem;
    transition: all 0.3s ease;
  }

  .search-bar input:focus {
    outline: none;
    border-color: var(--color-gold);
    box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.2);
  }

  .search-bar input::placeholder {
    color: var(--color-muted);
  }

  .search-bar .search-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-muted);
    font-size: 1.1rem;
  }

  .brand-table {
    width: 100%;
    border-collapse: collapse;
  }

  .brand-table th,
  .brand-table td {
    padding: 1.2rem 1.5rem;
    text-align: left;
    border-bottom: 1px solid var(--color-border);
  }

  .brand-table th {
    background: var(--color-dark);
    color: white;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.9rem;
    letter-spacing: 0.5px;
  }

  .brand-table tr:last-child td {
    border-bottom: none;
  }

  .brand-table tr:hover {
    background: #f8f9fa;
  }

  /* Pagination */
  .pagination {
    display: flex;
    justify-content: center;
    margin: 20px 0;
    flex-wrap: wrap;
    gap: 5px;
  }

  .pagination a {
    padding: 8px 12px;
    margin: 2px;
    border: 1px solid #ccc;
    border-radius: 5px;
    text-decoration: none;
    color: #333;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .pagination a:hover {
    background-color: #d4af37;
    color: white;
    border-color: #c19a2e;
    transform: translateY(-2px);
    box-shadow: 0 2px 5px rgba(0,0,0,0.2);
  }

  .pagination a.active {
    background-color: #1a1a1a;
    color: white;
    border-color: #1a1a1a;
    font-weight: 600;
  }

  @media (max-width: 600px) {
    .pagination a {
      padding: 6px 10px;
      font-size: 0.9rem;
    }
  }

  .action-btn {
    padding: 0.5rem 1rem;
    border: none;
    border-radius: 0.5rem;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.3s ease;
    min-width: 100px;
  }

  .block-btn {
    background: #ef4444;
    color: white;
  }

  .block-btn:hover {
    background: #dc2626;
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .unblock-btn {
    background: #22c55e;
    color: white;
  }

  .unblock-btn:hover {
    background: #16a34a;
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .status-text {
    font-weight: 600;
  }

  .status-active { color: #22c55e; }
  .status-blocked { color: #ef4444; }

  .no-brands {
    text-align: center;
    padding: 6rem 2rem;
    background: var(--color-card-bg);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }

  .no-brands h4 {
    font-size: 1.8rem;
    color: var(--color-dark);
    margin-bottom: 1rem;
  }

  @media (max-width: 992px) {
    .container {
      margin: 100px auto 80px;
    }
    .header-with-btn {
      flex-direction: column;
      align-items: stretch;
    }
    .add-btn {
      align-self: flex-end;
    }
  }
</style>

<div class="container">

  <div class="header-with-btn">
    <h2 class="page-title">Brand Management</h2>
    <button type="button" class="add-btn" data-bs-toggle="modal" data-bs-target="#addBrandModal">
      Add Brand
    </button>
  </div>

  <div class="search-bar">
    <div class="position-relative">
      <i class="bi bi-search search-icon"></i>
      <input type="text" id="searchInput" placeholder="Search brands..." value="<%= typeof search !== 'undefined' ? search : '' %>">
    </div>
  </div>

  <% if (brands && brands.length > 0) { %>
    <div class="table-wrapper">
      <table class="brand-table">
        <thead>
          <tr>
            <th>Brand Name</th>
            <th style="text-align: center;">Status</th>
            <th style="text-align: center;">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% brands.forEach((brand) => { %>
            <tr>
              <td><%= brand.name %></td>
              <td style="text-align: center;">
                <span class="status-text <%= brand.isBlocked ? 'status-blocked' : 'status-active' %>">
                  <%= brand.isBlocked ? 'Blocked' : 'Active' %>
                </span>
              </td>
              <td style="text-align: center;">
                <% if (brand.isBlocked) { %>
                  <button class="action-btn unblock-btn" data-id="<%= brand._id %>">
                    Unblock
                  </button>
                <% } else { %>
                  <button class="action-btn block-btn" data-id="<%= brand._id %>">
                    Block
                  </button>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="d-flex justify-content-center mt-4">
  <nav>
    <ul class="pagination">

      <!-- Previous -->
      <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
        <a class="page-link" href="?page=<%= currentPage - 1 %>">Previous</a>
      </li>

      <!-- Page Numbers -->
      <% for(let i = 1; i <= totalPages; i++) { %>
        <li class="page-item <%= currentPage === i ? 'active' : '' %>">
          <a class="page-link" href="?page=<%= i %>"><%= i %></a>
        </li>
      <% } %>

      <!-- Next -->
      <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
        <a class="page-link" href="?page=<%= currentPage + 1 %>">Next</a>
      </li>

    </ul>
  </nav>
</div>

  <% } else { %>
    <div class="no-brands">
      <h4>No brands found</h4>
      <p>No brands match your search.</p>
    </div>
  <% } %>
</div>

<!-- Add Brand Modal -->
<div class="modal fade" id="addBrandModal" tabindex="-1" aria-labelledby="addBrandLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="addBrandLabel">Add New Brand</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form id="brandForm">
          <div class="mb-3">
            <label for="name" class="form-label">Brand Name</label>
            <input type="text" class="form-control" id="name" name="name" placeholder="Enter brand name" required>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-success">Add Brand</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include("../../views/partials/admin/footer") %>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script>
  // Search Debounce
  let debounceTimer;
  document.getElementById("searchInput").addEventListener("keyup", function() {
    clearTimeout(debounceTimer);
    const searchTerm = this.value.trim();
    debounceTimer = setTimeout(() => {
      window.location.href = searchTerm === '' 
        ? '/admin/brand' 
        : `/admin/brand?search=${encodeURIComponent(searchTerm)}`;
    }, 500);
  });

  // Add Brand
  document.getElementById("brandForm").addEventListener("submit", async function (e) {
    e.preventDefault();
    const name = document.getElementById("name").value.trim();

    if (!name) {
      Swal.fire("Error", "Brand name is required", "error");
      return;
    }

    try {
      const response = await fetch("/admin/brand", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ name })
      });

      const result = await response.json();
      if (result.success) {
        Swal.fire("Success", result.message, "success").then(() => location.reload());
      } else {
        Swal.fire("Error", result.message, "error");
      }
    } catch (err) {
      Swal.fire("Error", "Something went wrong!", "error");
    }
  });

  // Block/Unblock
  document.querySelectorAll('.block-btn, .unblock-btn').forEach(btn => {
    btn.addEventListener('click', async function () {
      const id = btn.dataset.id;
      const isBlocked = btn.classList.contains('block-btn'); // true if currently "Block" (active → block)
      const action = isBlocked ? "block" : "unblock";

      const confirm = await Swal.fire({
        title: "Are you sure?",
        text: `Do you want to ${action} this brand?`,
        icon: "warning",
        showCancelButton: true,
        confirmButtonText: `Yes, ${action.charAt(0).toUpperCase() + action.slice(1)}`
      });

      if (!confirm.isConfirmed) return;

      try {
        const res = await fetch(`/admin/brand/block/${id}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        });
        const msg = await res.json();

        if (msg.success) {
          const row = btn.closest('tr');
          const statusCell = row.cells[1];
          if (msg.message === "block") {
            statusCell.innerHTML = '<span style="color: var(--danger); font-weight: 600;">Blocked</span>';
            btn.innerHTML = '<i class="fas fa-unlock me-1"></i> Unblock';
            btn.classList.remove('block-btn');
            btn.classList.add('unblock-btn');
          } else {
            statusCell.innerHTML = '<span style="color: var(--success); font-weight: 600;">Active</span>';
            btn.innerHTML = '<i class="fas fa-lock me-1"></i> Block';
            btn.classList.remove('unblock-btn');
            btn.classList.add('block-btn');
          }
          Swal.fire("Success", `Brand ${msg.message}ed successfully`, "success");
        } else {
          Swal.fire("Error", msg.message, "error");
        }
      } catch (err) {
        Swal.fire("Error", "Something went wrong!", "error");
      }
    });
  });
</script>

</body>
</html>