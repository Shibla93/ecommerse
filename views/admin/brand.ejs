<%- include("../../views/partials/admin/header") %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Brand Management</title>

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- SweetAlert2 -->
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">

  <style>
    :root {
      --bg-dark: #000000;
      --card-bg: #0f0f0f;
      --text-white: #ffffff;
      --text-muted: #bbbbbb;
      --gold: #e6c04a;
      --danger: #ef4444;
      --success: #22c55e;
      --border: #333333;
      --hover-bg: rgba(255, 255, 255, 0.05);
    }

    body {
      font-family: 'Montserrat', sans-serif;
      background: var(--bg-dark);
      color: var(--text-white);
      margin: 0;
      padding: 40px 20px;
      min-height: 100vh;
    }

    .container {
      max-width: 1400px;
      margin: 0 auto;
    }

    /* Header */
    .page-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 50px;
    }

    .page-header h2 {
      font-family: 'Playfair Display', serif;
      font-size: 3.2rem;
      font-weight: 700;
      color: var(--gold);
      margin: 0;
      letter-spacing: 1px;
    }

    .add-btn {
      padding: 14px 32px;
      background: var(--success);
      color: white;
      border: none;
      border-radius: 14px;
      font-weight: 600;
      font-size: 1.1rem;
      transition: all 0.4s ease;
      box-shadow: 0 4px 15px rgba(34, 197, 94, 0.3);
    }

    .add-btn:hover {
      background: #16a34a;
      transform: translateY(-3px);
      box-shadow: 0 8px 25px rgba(34, 197, 94, 0.5);
    }

    /* Search */
    .search-container {
      max-width: 680px;
      margin: 0 auto 50px;
      position: relative;
    }

    #searchInput {
      width: 100%;
      padding: 18px 60px 18px 56px;
      font-size: 1.15rem;
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 16px;
      color: var(--text-white);
      transition: all 0.4s ease;
    }

    #searchInput::placeholder {
      color: var(--text-muted);
    }

    #searchInput:focus {
      outline: none;
      border-color: var(--gold);
      box-shadow: 0 0 0 4px rgba(230, 192, 74, 0.2);
    }

    .search-icon {
      position: absolute;
      left: 22px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-white);
      opacity: 0.7;
      font-size: 1.4rem;
    }

    /* Table Card */
    .table-card {
      background: var(--card-bg);
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 15px 40px rgba(0, 0, 0, 0.7);
      border: 1px solid var(--border);
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin: 0;
    }

    thead {
      background: rgba(255, 255, 255, 0.05);
    }

    th {
      padding: 24px 20px;
      text-align: left;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      font-size: 0.85rem;
      color: var(--text-white);
    }

    td {
      padding: 24px 20px;
      border-top: 1px solid var(--border);
      color: var(--text-white);
      vertical-align: middle;
    }

    tr:hover {
      background: var(--hover-bg);
    }

    tr:nth-child(even) {
      background: rgba(255, 255, 255, 0.02);
    }

    /* Action Buttons */
    .action-btn {
      padding: 10px 20px;
      border: none;
      border-radius: 10px;
      font-weight: 600;
      font-size: 0.95rem;
      cursor: pointer;
      transition: all 0.3s ease;
      min-width: 100px;
    }

    .block-btn {
      background: var(--danger);
      color: white;
    }

    .block-btn:hover {
      background: #dc2626;
      transform: translateY(-2px);
    }

    .unblock-btn {
      background: var(--success);
      color: white;
    }

    .unblock-btn:hover {
      background: #16a34a;
      transform: translateY(-2px);
    }

    /* Pagination */
    .pagination {
      display: flex;
      justify-content: center;
      gap: 12px;
      margin-top: 50px;
    }

    .pagination a {
      padding: 14px 20px;
      min-width: 52px;
      text-align: center;
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 14px;
      color: var(--text-white);
      text-decoration: none;
      font-weight: 500;
      transition: all 0.4s ease;
    }

    .pagination a:hover {
      background: var(--gold);
      color: #000;
      border-color: var(--gold);
      transform: translateY(-4px);
    }

    .pagination a.active {
      background: var(--gold);
      color: #000;
      border-color: var(--gold);
      font-weight: 700;
    }

    /* Modals - Dark Theme Override */
    .modal-content {
      background: var(--card-bg);
      color: var(--text-white);
      border: 1px solid var(--border);
    }

    .modal-header {
      border-bottom: 1px solid var(--border);
    }

    .modal-footer {
      border-top: 1px solid var(--border);
    }

    .form-control, .form-control:focus {
      background: #1a1a1a;
      border-color: var(--border);
      color: var(--text-white);
    }

    .form-control::placeholder {
      color: var(--text-muted);
    }

    .btn-close-white {
      filter: invert(1);
    }

    /* Responsive */
    @media (max-width: 992px) {
      .page-header { flex-direction: column; gap: 20px; text-align: center; }
      .page-header h2 { font-size: 2.8rem; }
      table, thead, tbody, th, td, tr { display: block; }
      thead tr { display: none; }
      tr { border-bottom: 3px solid var(--border); margin-bottom: 24px; border-radius: 16px; overflow: hidden; background: rgba(255,255,255,0.03); }
      td {
        position: relative;
        padding-left: 50%;
        text-align: right;
      }
      td:before {
        content: attr(data-label);
        position: absolute;
        left: 24px;
        width: 45%;
        font-weight: 600;
        text-align: left;
        color: var(--gold);
      }
      td:last-child { text-align: center; padding: 20px; }
    }

    @media (max-width: 576px) {
      .page-header h2 { font-size: 2.4rem; }
      #searchInput { padding: 16px 50px 16px 50px; }
    }
  </style>
</head>
<body>

<div class="container">

  <!-- Page Header -->
  <div class="page-header">
    <h2>BRAND MANAGEMENT</h2>
    <button type="button" class="add-btn" data-bs-toggle="modal" data-bs-target="#addBrandModal">
      <i class="fas fa-plus me-2"></i> Add Brand
    </button>
  </div>

  <!-- Search -->
  <div class="search-container">
    <i class="fas fa-search search-icon"></i>
    <input type="text" id="searchInput" placeholder="Search brands..." value="<%= typeof search !== 'undefined' ? search : '' %>">
  </div>

  <!-- Table Card -->
  <div class="table-card">
    <table>
      <thead>
        <tr>
          <th>Brand Name</th>
          <th style="text-align: center;">Status</th>
          <th style="text-align: center;">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (brands.length === 0) { %>
          <tr>
            <td colspan="3" style="text-align: center; padding: 60px; color: var(--text-muted);">
              No brands found
            </td>
          </tr>
        <% } else { %>
          <% brands.forEach((brand) => { %>
            <tr>
              <td data-label="Brand Name"><%= brand.name %></td>
              <td data-label="Status" style="text-align: center;">
                <% if (brand.isBlocked) { %>
                  <span style="color: var(--danger); font-weight: 600;">Blocked</span>
                <% } else { %>
                  <span style="color: var(--success); font-weight: 600;">Active</span>
                <% } %>
              </td>
              <td data-label="Actions" style="text-align: center;">
                <% if (brand.isBlocked) { %>
                  <button class="action-btn unblock-btn" data-id="<%= brand._id %>">
                    <i class="fas fa-unlock me-1"></i> Unblock
                  </button>
                <% } else { %>
                  <button class="action-btn block-btn" data-id="<%= brand._id %>">
                    <i class="fas fa-lock me-1"></i> Block
                  </button>
                <% } %>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>

    <!-- Pagination -->
    <% if (totalPages > 1) { %>
    <div class="pagination">
      <% for(let i = 1; i <= totalPages; i++) { %>
        <a href="/admin/brand?page=<%= i %>&search=<%= encodeURIComponent(search || '') %>"
           class="<%= currentPage === i ? 'active' : '' %>">
          <%= i %>
        </a metering>
      <% } %>
    </div>
    <% } %>
  </div>
</div>

<!-- Add Brand Modal -->
<div class="modal fade" id="addBrandModal" tabindex="-1" aria-labelledby="addBrandLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="addBrandLabel">Add New Brand</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form id="brandForm">
          <div class="mb-3">
            <label for="name" class="form-label">Brand Name</label>
            <input type="text" class="form-control" id="name" name="name" placeholder="Enter brand name" required>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-success">Add Brand</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include("../../views/partials/admin/footer") %>

<script>
  // Search Debounce
  let debounceTimer;
  document.getElementById("searchInput").addEventListener("keyup", function() {
    clearTimeout(debounceTimer);
    const searchTerm = this.value.trim();
    debounceTimer = setTimeout(() => {
      window.location.href = searchTerm === '' 
        ? '/admin/brand' 
        : `/admin/brand?search=${encodeURIComponent(searchTerm)}`;
    }, 500);
  });

  // Add Brand
  document.getElementById("brandForm").addEventListener("submit", async function (e) {
    e.preventDefault();
    const name = document.getElementById("name").value.trim();

    if (!name) {
      Swal.fire("Error", "Brand name is required", "error");
      return;
    }

    try {
      const response = await fetch("/admin/brand", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ name })
      });

      const result = await response.json();
      if (result.success) {
        Swal.fire("Success", result.message, "success").then(() => location.reload());
      } else {
        Swal.fire("Error", result.message, "error");
      }
    } catch (err) {
      Swal.fire("Error", "Something went wrong!", "error");
    }
  });

  // Block/Unblock
  document.querySelectorAll('.block-btn, .unblock-btn').forEach(btn => {
    btn.addEventListener('click', async function () {
      const id = btn.dataset.id;
      const isBlocked = btn.classList.contains('block-btn'); // true if currently "Block" (active → block)
      const action = isBlocked ? "block" : "unblock";

      const confirm = await Swal.fire({
        title: "Are you sure?",
        text: `Do you want to ${action} this brand?`,
        icon: "warning",
        showCancelButton: true,
        confirmButtonText: `Yes, ${action.charAt(0).toUpperCase() + action.slice(1)}`
      });

      if (!confirm.isConfirmed) return;

      try {
        const res = await fetch(`/admin/brand/block/${id}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        });
        const msg = await res.json();

        if (msg.success) {
          const row = btn.closest('tr');
          const statusCell = row.cells[1];
          if (msg.message === "block") {
            statusCell.innerHTML = '<span style="color: var(--danger); font-weight: 600;">Blocked</span>';
            btn.innerHTML = '<i class="fas fa-unlock me-1"></i> Unblock';
            btn.classList.remove('block-btn');
            btn.classList.add('unblock-btn');
          } else {
            statusCell.innerHTML = '<span style="color: var(--success); font-weight: 600;">Active</span>';
            btn.innerHTML = '<i class="fas fa-lock me-1"></i> Block';
            btn.classList.remove('unblock-btn');
            btn.classList.add('block-btn');
          }
          Swal.fire("Success", `Brand ${msg.message}ed successfully`, "success");
        } else {
          Swal.fire("Error", msg.message, "error");
        }
      } catch (err) {
        Swal.fire("Error", "Something went wrong!", "error");
      }
    });
  });
</script>

</body>
</html>