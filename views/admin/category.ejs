
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Category Management</title>

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Bootstrap JS Bundle -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

  <style>
    body {
      font-family: Arial, sans-serif;
      background:rgba(0, 0, 0, 0);
      margin: 0;
      padding: 20px;
      color: #333;
    }
    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
   
    }
    .header h2 {
      margin: 0;
    }

    /* Search */
    .search-container {
      text-align: center;
      margin-bottom: 20px;
    }
    .search-container input[type="text"] {
      padding: 8px 12px;
      width: 250px;
      border: 1px solid #ccc;
      border-radius: 4px;
      font-size: 14px;
    }
    .search-container .search-btn,
    .search-container .clear-btn {
      padding: 8px 14px;
      margin-left: 5px;
      border: none;
      border-radius: 4px;
      font-size: 14px;
      cursor: pointer;
      color: #fff;
      transition: 0.3s;
    }
    .search-container .search-btn {
      background-color: #007bff;
    }
    .search-container .search-btn:hover {
      background-color: #0069d9;
    }
    .search-container .clear-btn {
      background-color: #6c757d;
    }
    .search-container .clear-btn:hover {
      background-color: #5a6268;
    }

    /* Table */
    .table-container {
      width: 100%;
      background: #fff;
      padding: 40px;
      border-radius: 8px;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
      color: black;
      overflow-x:auto;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 15px;
    }
    thead {
      background: #f4f4f4;
      font-size: 16px;
    }
    th, td {
      padding: 15px 20px;
      text-align: left;
      border-bottom: 1px solid #ddd;
       white-space: nowrap; 
    }
    tr:hover {
      background: #f9f9f9;
    }
    .action-btn {
      padding: 6px 12px;
      border: none;
      border-radius: 4px;
      font-size: 13px;
      cursor: pointer;
      margin-right: 5px;
    }
    .edit-btn {
      background-color: #007bff;
      color: white;
    }
    .edit-btn:hover {
      background-color: #0056b3;
    }
    .delete-btn {
      background-color: #dc3545;
      color: white;
    }
    .delete-btn:hover {
      background-color: #b02a37;
    }

    /* Pagination */
    .pagination {
      text-align: center;
      margin-top: 20px;
      justify-content: center;
      align-items: center;
    }
    .pagination a {
      display: inline-block;
      padding: 8px 12px;
      margin: 0 4px;
      border: 1px solid #ccc;
      border-radius: 4px;
      color: black;
      text-decoration: none;
    }
    .pagination a.active {
      background-color: #007bff;
      color: white;
      border-color: #007bff;
    }
    .pagination a:hover {
      background-color: #ddd;
    }
    
     .error {
      color: red;
      font-size: 12px;
      margin-top: 5px;
      display: none;
    }
  </style>
</head>
<body>
<%- include("../../views/partials/admin/header") %>
  <!-- Header -->
  <div class="header">
    <h2>Category Management</h2>
    <!-- Add Category Button -->
    <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addCategoryModal">
      + Add Category
    </button>
  </div>

  <!-- Search -->
  <form action="/admin/category" method="GET" class="search-container">
    <input id="searchInput" type="text" name="search" placeholder="Search categories..." value="<%= typeof search !== 'undefined' ? search : '' %>">

  </form>

  <!-- Table -->
  <div class="table-container">
    <table class="table">
      <thead>
        <tr>
          <th>Category Name</th>
          <th>Description</th>
    
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% category.forEach((cat) => { %>
          <tr>
            <td><%= cat.name %></td>
            <td><%= cat.description %></td>
      
        
 <td> 
  <% if (cat.isListed) { %>
    <button class="btn btn-sm btn-success list-btn" data-id="<%= cat._id %>">
      Unlist
    </button>
  <% } else { %>
    <button class="btn btn-sm btn-danger list-btn" data-id="<%= cat._id %>">
      list
    </button>
  <% } %>
</td>

      
<td>
  <a href="#" class="action-btn edit-btn"
     data-id="<%= cat._id %>"
     data-name="<%= cat.name %>"
     data-description="<%= cat.description %>"
     onclick="openEditModal(this)">
    Edit
  </a>

              <a href="#" class="action-btn delete-btn" onclick="deleteCategory('<%=cat._id %>')">Delete</a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>


  <!-- Pagination -->
  <div class="pagination">
            <% for(let i = 1; i <= totalPages; i++) { %>
                <a href="/admin/category?page=<%= i %>&search=<%= search %>" 
                   class="<%= currentPage === i ? 'active' : '' %>">
                   <%= i %>
                </a>
            <% } %>
        </div>
  

  <!-- Add Category Modal -->
  <div class="modal fade" id="addCategoryModal" tabindex="-1" aria-labelledby="addCategoryLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="addCategoryLabel">Add New Category</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <form action="/admin/category" id="form" method="POST" >
            <div class="mb-3">
              <label for="name" class="form-label">Category Name</label>
              <input type="text" class="form-control" id="name" name="name" >
              <div class="error" id="er1"></div>
            </div>

            <div class="mb-3">
              <label for="description" class="form-label">Description</label>
              <textarea class="form-control" id="description" name="description"></textarea>
              <div class="error" id="er2"></div>
            </div>

            

            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
              <button type="submit" class="btn btn-success">Add Category</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

<!-- Edit Category Modal -->
<div class="modal fade" id="editCategoryModal" tabindex="-1" aria-labelledby="editCategoryLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="editCategoryLabel">Edit Category</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form id="editForm" method="POST" action="/admin/category">
          <div class="mb-3">
            <label for="editName" class="form-label">Category Name</label>
            <input type="text" class="form-control" id="editName" name="name">
          </div>

          <div class="mb-3">
            <label for="editDescription" class="form-label">Description</label>
            <textarea class="form-control" id="editDescription" name="description"></textarea>
          </div>

          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary">Update Category</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>


</body>
</html>
 <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<%- include("../../views/partials/admin/footer") %>
<script>
   let debounceTimer;

  document.getElementById("searchInput").addEventListener("keyup", function() {
    clearTimeout(debounceTimer);

    const searchTerm = this.value.trim();

    
    debounceTimer = setTimeout(() => {
      if (searchTerm === '') {
        window.location.href = '/admin/category';
      } else {
        window.location.href = `/admin/category?search=${encodeURIComponent(searchTerm)}`;
      }
    }, 500);
  });
  const form = document.querySelector('#form');
  const nameInput = document.getElementById('name');
  const descInput = document.getElementById('description');

  const er1 = document.getElementById('er1');
  const er2 = document.getElementById('er2');
  

  form.addEventListener('submit', (e) => {
    let valid = true;

    
    er1.style.display = 'none';
    er2.style.display = 'none';
    

    
    if (nameInput.value.trim() === '') {
      er1.innerText = 'Category name is required';
      er1.style.display = 'block';
      valid = false;
    }

    
    if (descInput.value.trim() === '') {
      er2.innerText = 'Description is required';
      er2.style.display = 'block';
      valid = false;
    }


    if (!valid) {
      e.preventDefault(); 
    }
  });


 document.getElementById("form").addEventListener("submit", async function (e) {
    e.preventDefault();

    const name = document.getElementById("name").value;
     const description = document.getElementById("description").value.trim();


    try {
      const response = await fetch("/admin/category", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ name,description })
      });

      const result = await response.json();

      if (result.success) {
        Swal.fire("Success", result.message, "success").then(() => {
          location.reload(); 
        });
      } else {
        Swal.fire("Error", result.message, "error");
      }

    } catch (err) {
      Swal.fire("Error", "Something went wrong!", "error");
    }
  });


async function confirmAction(action) {
  return Swal.fire({
    title: "Are you sure?",
    text: `Do you want to ${action} this category?`,
    icon: "warning",
    showCancelButton: true,
    confirmButtonColor: "#3085d6",
    cancelButtonColor: "#d33",
    confirmButtonText: `Yes, ${action}`
  }).then(result => result.isConfirmed);
}









document.querySelectorAll('.list-btn').forEach(btn => {
  
  btn.addEventListener('click',async function () {
    const id = btn.dataset.id;
     const action = btn.classList.contains("btn-success") ? "Unlist" : "List";
const ok = await confirmAction(action);
    if (!ok) return;
    try{

   const res= await fetch(`/admin/category/list/${id}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' }
    })
    
    const msg= await res.json()
    if(msg.success){
        if(msg.message === "unlisted"){
          btn.textContent="List"
         
            btn.classList.remove("btn-success");
        btn.classList.add("btn-danger");
        }else if(msg.message === "listed"){
          btn.textContent="Unlist"
            btn.classList.remove("btn-danger");
        btn.classList.add("btn-success")
        }
        Swal.fire("Success", `Category ${msg.message} successfully`, "success");
    
   }else{
     Swal.fire("Error", msg.message, "error");
   }

    }catch(err){
  Swal.fire("Error", "Something went wrong!", "error");
    }
  })
})



function openEditModal(element) {

  const id = element.dataset.id;
  const name = element.dataset.name;
  const description = element.dataset.description;

  document.getElementById('editName').value = name;
  document.getElementById('editDescription').value = description;


  document.getElementById('editForm').action = `/admin/category/${id}`;

  
  const modal = new bootstrap.Modal(document.getElementById('editCategoryModal'));
  modal.show();
}



document.getElementById('editForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const form = e.target;
  const id = form.action.split('/').pop();
  const name = document.getElementById('editName').value.trim();
  const description = document.getElementById('editDescription').value.trim();

  if (!name || !description) {
    Swal.fire('Error', 'All fields are required', 'error');
    return;
  }

  try {
    const res = await fetch(`/admin/category/${id}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, description })
    });
    const data = await res.json();

    if (data.success) {
      Swal.fire('Success', data.message, 'success').then(() => {
        location.reload(); 
      });
    } else {
      Swal.fire('Error', data.message || 'Something went wrong', 'error');
    }
  } catch (err) {
    console.error(err);
    Swal.fire('Error', 'Server error', 'error');
  }
});


function deleteCategory(id) {
  Swal.fire({
    title: "Delete?",
    text: "Are you sure?",
    icon: "warning",
    showCancelButton: true,
    confirmButtonText: "Yes",
    cancelButtonText: "No"
  }).then((res) => {
    if (res.isConfirmed) {
      fetch(`/admin/category/delete/${id}`, { method: "PUT" })
        .then(r => r.json())
        .then(d => {
          Swal.fire(d.success ? "Deleted!" : "Error", d.message, d.success ? "success" : "error")
            .then(() => { if (d.success) location.reload(); });
        });
    }
  });
}

  

</script>
