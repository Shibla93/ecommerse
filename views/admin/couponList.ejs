<%- include("../../views/partials/admin/header") %>

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - Coupon Management</title>

  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" 
        rel="stylesheet" 
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" 
        crossorigin="anonymous">

  <!-- Font Awesome 6 -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

  <style>
    /* Your existing styles – kept as-is */
    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      background-color: #f5f7ff;
      color: #333;
    }

    .main-content {
      background: #f5f7ff;
      min-height: calc(100vh - 70px);
    }

    .card {
      border-radius: 12px;
      overflow: hidden;
      border: none;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .card:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

    .table {
      border-radius: 8px;
      overflow: hidden;
    }

    .table thead th {
      background: #2c3e50 !important;
      color: white;
      text-transform: uppercase;
      font-size: 0.85rem;
      letter-spacing: 0.5px;
      border: none;
    }

    .table tbody tr {
      transition: background 0.15s;
    }

    .table tbody tr:hover {
      background-color: #f1f5f9;
    }

    .table td {
      vertical-align: middle;
      font-size: 0.95rem;
    }

    strong {
      color: #1e293b;
    }

    .badge {
      font-weight: 500;
      padding: 0.45em 0.9em;
      border-radius: 1rem;
    }

    .bg-success { background-color: #198754 !important; }
    .bg-danger   { background-color: #dc3545 !important; }
    .bg-warning  { background-color: #ffc107 !important; color: #000; }
    .bg-secondary { background-color: #6c757d !important; }

    .btn-sm {
      padding: 0.4rem 0.75rem;
      font-size: 0.875rem;
    }

    .btn-outline-primary {
      border-color: #0d6efd;
      color: #0d6efd;
    }

    .btn-outline-primary:hover {
      background: #0d6efd;
      color: white;
    }

    .btn-outline-danger {
      border-color: #dc3545;
      color: #dc3545;
    }

    .btn-outline-danger:hover {
      background: #dc3545;
      color: white;
    }

    .alert {
      border-radius: 8px;
      border: none;
    }

    .modal-content {
      border-radius: 12px;
      border: none;
      box-shadow: 0 10px 40px rgba(0,0,0,0.2);
    }

    .modal-header {
      background: #2c3e50;
      color: white;
      border-top-left-radius: 12px;
      border-top-right-radius: 12px;
    }

    .form-label {
      font-weight: 500;
      color: #1e293b;
    }

    .form-control, .form-select {
      border-radius: 8px;
    }
  </style>
</head>

<div class="main-content p-4">
  <div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
      <h2 class="mb-0">Coupon Management</h2>
      <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createCouponModal">
        <i class="fas fa-plus me-2"></i> Create New Coupon
      </button>
    </div>

    <% if (typeof message !== 'undefined' && message) { %>
      <div class="alert alert-<%= message.type || 'info' %> alert-dismissible fade show" role="alert">
        <%= message.text %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>

    <% if (coupons && coupons.length > 0) { %>
      <div class="card shadow-sm border-0">
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-dark">
                <tr>
                  <th>Code</th>
                  <th>Type</th>
                  <th>Value</th>
                  <th>Min Purchase</th>
                  <th>Max Discount</th>
                  <th>Usage / Limit</th>
                  <th>Expiry</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% coupons.forEach(coupon => { %>
                  <tr>
                    <td><strong><%= coupon.code %></strong></td>
                    <td><%= coupon.discountType === 'percentage' ? 'Percentage' : 'Flat' %></td>
                    <td>
                      <%= coupon.discountValue %>
                      <%= coupon.discountType === 'percentage' ? '%' : '₹' %>
                    </td>
                    <td>₹<%= Number(coupon.minPurchase || 0).toFixed(2) %></td>
                    <td><%= coupon.maxDiscount ? '₹' + Number(coupon.maxDiscount).toFixed(2) : '—' %></td>
                    <td><%= coupon.usedBy?.length || 0 %> / <%= coupon.usageLimit %></td>
                    <td>
                      <%= new Date(coupon.expiryDate).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                      <% if (new Date(coupon.expiryDate) < new Date()) { %>
                        <span class="badge bg-danger ms-2">Expired</span>
                      <% } %>
                    </td>
                    <td>
                      <% if (!coupon.isActive) { %>
                        <span class="badge bg-secondary">Inactive</span>
                      <% } else if (new Date(coupon.expiryDate) <=new Date()) { %>
                        <span class="badge bg-danger">Expired</span>
                      <% } else if ((coupon.usedBy?.length || 0) >= coupon.usageLimit) { %>
                        <span class="badge bg-warning">Limit Reached</span>
                      <% } else { %>
                        <span class="badge bg-success">Active</span>
                      <% } %>
                    </td>
                    <td>
                      <button 
                        class="btn btn-sm btn-outline-primary me-2 edit-btn"
                        data-bs-toggle="modal"
                        data-bs-target="#editCouponModal"
                        data-id="<%= coupon._id %>"
                        data-code="<%= coupon.code %>"
                        data-type="<%= coupon.discountType %>"
                        data-value="<%= coupon.discountValue %>"
                        data-min="<%= coupon.minPurchase || 0 %>"
                        data-max="<%= coupon.maxDiscount || '' %>"
                        data-limit="<%= coupon.usageLimit %>"
                        data-expiry="<%= new Date(coupon.expiryDate).toISOString().split('T')[0] %>"
                        data-active="<%= coupon.isActive %>"
                      >
                        <i class="fas fa-edit"></i>
                      </button>

                   <form action="/admin/coupons/<%= coupon._id %>/delete" 
      method="POST" 
      class="d-inline delete-form"
      data-code="<%= coupon.code %>">
  <button type="submit" class="btn btn-sm btn-outline-danger">
    <i class="fas fa-trash"></i>
  </button>
</form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    <% } else { %>
      <div class="alert alert-info text-center py-5">
        <i class="fas fa-ticket-alt fa-3x mb-3 d-block text-muted"></i>
        <h5>No coupons found</h5>
        <p>Create your first coupon to get started.</p>
        <button type="button" class="btn btn-primary mt-3" data-bs-toggle="modal" data-bs-target="#createCouponModal">
          Create Coupon
        </button>
      </div>
    <% } %>

  </div>
</div>

<!-- CREATE COUPON MODAL -->
<div class="modal fade" id="createCouponModal" tabindex="-1" aria-labelledby="createCouponModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="createCouponModalLabel">Create New Coupon</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      
      <form action="/admin/coupons" method="POST">
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-md-6">
              <label for="create_code" class="form-label">Coupon Code <span class="text-danger">*</span></label>
              <input type="text" class="form-control text-uppercase" id="create_code" name="code" 
                     placeholder="SUMMER25" required maxlength="20">
              <div class="form-text">Will be saved in uppercase</div>
            </div>

            <div class="col-md-6">
              <label for="create_discountType" class="form-label">Discount Type <span class="text-danger">*</span></label>
              <select class="form-select" id="create_discountType" name="discountType" required>
                <option value="" disabled selected>Select type</option>
                <option value="percentage">Percentage (%)</option>
                <option value="flat">Flat Amount (₹)</option>
              </select>
            </div>

            <div class="col-md-6">
              <label for="create_discountValue" class="form-label">Discount Value <span class="text-danger">*</span></label>
              <input type="number" class="form-control" id="create_discountValue" name="discountValue" 
                     min="0.01" step="0.01" required placeholder="25 or 150">
            </div>

            <div class="col-md-6">
              <label for="create_minPurchase" class="form-label">Minimum Purchase (₹)</label>
              <input type="number" class="form-control" id="create_minPurchase" name="minPurchase" 
                     min="0" step="0.01" value="0">
              <div class="form-text">0 = no minimum required</div>
            </div>

            <div class="col-md-6">
              <label for="create_maxDiscount" class="form-label">Maximum Discount Cap (₹) <small class="text-muted">(for % only)</small></label>
              <input type="number" class="form-control" id="create_maxDiscount" name="maxDiscount" 
                     min="0" step="0.01">
            </div>

            <div class="col-md-6">
              <label for="create_usageLimit" class="form-label">Usage Limit</label>
              <input type="number" class="form-control" id="create_usageLimit" name="usageLimit" 
                     min="1" value="1">
              <div class="form-text">Total number of uses allowed</div>
            </div>

            <div class="col-md-6">
              <label for="create_expiryDate" class="form-label">Expiry Date <span class="text-danger">*</span></label>
              <input type="date" class="form-control" id="create_expiryDate" name="expiryDate" required>
            </div>

            <div class="col-12">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="isActive" id="create_isActive" checked>
                <label class="form-check-label" for="create_isActive">
                  Coupon is active (visible to users)
                </label>
              </div>
            </div>
          </div>
        </div>

        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">
            <i class="fas fa-save me-2"></i> Create Coupon
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- EDIT COUPON MODAL -->
<div class="modal fade" id="editCouponModal" tabindex="-1" aria-labelledby="editCouponModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="editCouponModalLabel">Edit Coupon</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      
      <form id="editCouponForm" action="" method="POST">
        <input type="hidden" name="_method" value="PUT">
        
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-md-6">
              <label for="edit_code" class="form-label">Coupon Code <span class="text-danger">*</span></label>
              <input type="text" class="form-control text-uppercase" id="edit_code" name="code" required maxlength="20">
              <div class="form-text">Will be saved in uppercase</div>
            </div>

            <div class="col-md-6">
              <label for="edit_discountType" class="form-label">Discount Type <span class="text-danger">*</span></label>
              <select class="form-select" id="edit_discountType" name="discountType" required>
                <option value="percentage">Percentage (%)</option>
                <option value="flat">Flat Amount (₹)</option>
              </select>
            </div>

            <div class="col-md-6">
              <label for="edit_discountValue" class="form-label">Discount Value <span class="text-danger">*</span></label>
              <input type="number" class="form-control" id="edit_discountValue" name="discountValue" 
                     min="0.01" step="0.01" required>
            </div>

            <div class="col-md-6">
              <label for="edit_minPurchase" class="form-label">Minimum Purchase (₹)</label>
              <input type="number" class="form-control" id="edit_minPurchase" name="minPurchase" min="0" step="0.01">
            </div>

            <div class="col-md-6">
              <label for="edit_maxDiscount" class="form-label">Maximum Discount Cap (₹) <small class="text-muted">(for % only)</small></label>
              <input type="number" class="form-control" id="edit_maxDiscount" name="maxDiscount" min="0" step="0.01">
            </div>

            <div class="col-md-6">
              <label for="edit_usageLimit" class="form-label">Usage Limit</label>
              <input type="number" class="form-control" id="edit_usageLimit" name="usageLimit" min="1">
            </div>

            <div class="col-md-6">
              <label for="edit_expiryDate" class="form-label">Expiry Date <span class="text-danger">*</span></label>
              <input type="date" class="form-control" id="edit_expiryDate" name="expiryDate" required>
            </div>

            <div class="col-12">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="isActive" id="edit_isActive">
                <label class="form-check-label" for="edit_isActive">
                  Coupon is active (visible to users)
                </label>
              </div>
            </div>
          </div>
        </div>

        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">
            <i class="fas fa-save me-2"></i> Update Coupon
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
   <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" 
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" 
        crossorigin="anonymous"></script>

<script>
  // Uppercase for create modal
  document.getElementById('create_code')?.addEventListener('input', function() {
    this.value = this.value.toUpperCase().trim();
  });

  // Populate edit modal when edit button is clicked
  document.querySelectorAll('.edit-btn').forEach(button => {
    button.addEventListener('click', function() {
      const modal = document.getElementById('editCouponModal');
      const form = document.getElementById('editCouponForm');

      // Set form action dynamically with coupon ID
      const couponId = this.getAttribute('data-id');
      form.action = `/admin/coupons/${couponId}/edit`;

      // Fill fields
      document.getElementById('edit_code').value = this.getAttribute('data-code') || '';
      document.getElementById('edit_discountType').value = this.getAttribute('data-type') || 'percentage';
      document.getElementById('edit_discountValue').value = this.getAttribute('data-value') || '';
      document.getElementById('edit_minPurchase').value = this.getAttribute('data-min') || '0';
      document.getElementById('edit_maxDiscount').value = this.getAttribute('data-max') || '';
      document.getElementById('edit_usageLimit').value = this.getAttribute('data-limit') || '1';
      document.getElementById('edit_expiryDate').value = this.getAttribute('data-expiry') || '';
      
      // Checkbox
      const isActive = this.getAttribute('data-active') === 'true';
      document.getElementById('edit_isActive').checked = isActive;

      // Optional: Uppercase live in edit too
      const editCodeInput = document.getElementById('edit_code');
      editCodeInput.addEventListener('input', function() {
        this.value = this.value.toUpperCase().trim();
      }, { once: true }); // only once per modal open
    });
  });
  
document.querySelectorAll(".delete-form").forEach(form => {
  form.addEventListener("submit", function (e) {
    e.preventDefault();

    const couponCode = this.getAttribute("data-code");

    Swal.fire({
      title: "Are you sure?",
      text: `Deactivate coupon ${couponCode}?`,
      icon: "warning",
      showCancelButton: true,
      confirmButtonColor: "#dc3545",
      cancelButtonColor: "#6c757d",
      confirmButtonText: "Yes, deactivate it!",
      cancelButtonText: "Cancel"
    }).then((result) => {
      if (result.isConfirmed) {
        this.submit();
      }
    });
  });
});

</script>

<%- include("../../views/partials/admin/footer") %>