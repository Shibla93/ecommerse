<%- include("../../views/partials/admin/header") %>

  <style>
    :root {
      --color-gold: #d4af37;
      --color-gold-hover: #c19a2e;
      --color-dark: #1a1a1a;
      --color-muted: #6b7280;
      --color-border: #e5e7eb;
      --color-card-bg: #ffffff;
      --color-light-bg: #f9fafb;
      --radius-lg: 1rem;
      --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
      --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
      --danger: #ef4444;
      --success: #22c55e;
    }

    body {
      font-family: 'Montserrat', sans-serif;
      background: var(--color-light-bg);
      min-height: 100vh;
    }

    .container {
      max-width: 1400px;
      margin: 120px auto 80px;
      padding: 0 20px;
    }

    .page-title {
      font-size: 2.5rem;
      font-weight: 700;
      color: var(--color-dark);
      text-align: center;
      margin-bottom: 2.5rem;
      border-bottom: 2px solid var(--color-gold);
      display: inline-block;
      padding-bottom: 0.5rem;
    }
    .pagination .page-link {
  color: #d4af37;
  border-radius: 8px;
}

.pagination .active .page-link {
  background-color: #d4af37;
  border-color: #d4af37;
  color: white;
}
    .create-btn {
      background: var(--color-gold);
      color: white;
      padding: 0.9rem 2rem;
      border: none;
      border-radius: 0.75rem;
      font-size: 1.1rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      display: block;
      margin: 0 auto 3rem;
    }

    .create-btn:hover {
      background: var(--color-gold-hover);
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }

    .table-wrapper {
      background: var(--color-card-bg);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-lg);
      overflow: hidden;
    }

    .coupons-table {
      width: 100%;
      border-collapse: collapse;
    }

    .coupons-table th,
    .coupons-table td {
      padding: 1.2rem 1.5rem;
      text-align: left;
      border-bottom: 1px solid var(--color-border);
    }

    .coupons-table th {
      background: var(--color-dark);
      color: white;
      font-weight: 600;
      text-transform: uppercase;
      font-size: 0.9rem;
      letter-spacing: 0.5px;
    }

    .coupons-table tr:hover {
      background: #f8f9fa;
    }

    .badge {
      padding: 0.45em 0.9em;
      border-radius: 20px;
      font-weight: 600;
      font-size: 0.85rem;
    }

    .error-text {
      color: red;
      font-size: 0.85rem;
      margin-top: 4px;
    }

    .input-error {
      border: 1px solid red !important;
    }

    .action-btn {
      padding: 0.5rem 1rem;
      border: none;
      border-radius: 0.5rem;
      font-size: 0.9rem;
      cursor: pointer;
      transition: all 0.3s ease;
      margin-right: 0.5rem;
    }

    .edit-btn {
      background: #007bff;
      color: white;
    }

    .delete-btn {
      background: var(--danger);
      color: white;
    }

    .action-btn:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }

    .no-coupons {
      text-align: center;
      padding: 6rem 2rem;
      background: var(--color-card-bg);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-lg);
    }

    .no-coupons h4 {
      font-size: 1.8rem;
      color: var(--color-dark);
      margin-bottom: 1rem;
    }

    .modal-content {
      border-radius: var(--radius-lg);
      border: none;
      box-shadow: var(--shadow-lg);
    }

    .modal-header {
      background: var(--color-dark);
      color: white;
      border-bottom: 3px solid var(--color-gold);
    }

    .modal-title {
      font-weight: 600;
      color: var(--color-gold);
    }

    .form-label {
      font-weight: 600;
      color: var(--color-dark);
    }

    .form-control,
    .form-select {
      border-radius: 0.75rem;
      padding: 0.8rem 1rem;
    }

    .form-control:focus,
    .form-select:focus {
      border-color: var(--color-gold);
      box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.2);
    }

    @media (max-width: 992px) {
      .container {
        margin: 100px auto 80px;
      }
    }
  </style>

  <div class="container">
    <h2 class="page-title">Coupon Management</h2>

    <button type="button" class="create-btn" data-bs-toggle="modal" data-bs-target="#createCouponModal">
      <i class="fas fa-plus me-2"></i> Create New Coupon
    </button>

    <% if (typeof message !=='undefined' && message) { %>
      <div class="alert alert-<%= message.type || 'info' %> alert-dismissible fade show" role="alert">
        <%= message.text %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
      <% } %>

        <% if (coupons && coupons.length> 0) { %>
          <div class="table-wrapper">
            <table class="coupons-table">
              <thead>
                <tr>
                  <th>Code</th>
                  <th>Type</th>
                  <th>Value</th>
                  <th>Min Purchase</th>
                  <th>Max Discount</th>
                  <th>Usage / Limit</th>
                  <th>Expiry</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% coupons.forEach(coupon=> { %>
                  <tr>
                    <td><strong>
                        <%= coupon.code %>
                      </strong></td>
                    <td>
                      <%= coupon.discountType==='percentage' ? 'Percentage' : 'Flat' %>
                    </td>
                    <td>
                      <%= coupon.discountValue %>
                        <%= coupon.discountType==='percentage' ? '%' : '₹' %>
                    </td>
                    <td>₹<%= Number(coupon.minPurchase || 0).toFixed(2) %>
                    </td>
                    <td>
                      <%= coupon.maxDiscount ? '₹' + Number(coupon.maxDiscount).toFixed(2) : '—' %>
                    </td>
                    <td>
                      <%= coupon.usedBy?.length || 0 %> / <%= coupon.usageLimit %>
                    </td>
                    <td>
                      <%= new Date(coupon.expiryDate).toLocaleDateString('en-IN', { day: '2-digit' , month: 'short' ,
                        year: 'numeric' }) %>
                    </td>
                    <td>
                      <% if (!coupon.isActive) { %>
                        <span class="badge bg-secondary">Inactive</span>
                        <% } else if (new Date(coupon.expiryDate) < new Date()) { %>
                          <span class="badge bg-danger">Expired</span>
                          <% } else if ((coupon.usedBy?.length || 0)>= coupon.usageLimit) { %>
                            <span class="badge bg-warning">Limit Reached</span>
                            <% } else { %>
                              <span class="badge bg-success">Active</span>
                              <% } %>
                    </td>
                    <td>
                      <button class="action-btn edit-btn" data-bs-toggle="modal" data-bs-target="#editCouponModal"
                        data-id="<%= coupon._id %>" data-code="<%= coupon.code %>"
                        data-type="<%= coupon.discountType %>" data-value="<%= coupon.discountValue %>"
                        data-min="<%= coupon.minPurchase || 0 %>" data-max="<%= coupon.maxDiscount || '' %>"
                        data-limit="<%= coupon.usageLimit %>"
                        data-expiry="<%= new Date(coupon.expiryDate).toISOString().split('T')[0] %>"
                        data-active="<%= coupon.isActive %>">
                        Edit
                      </button>

                      <form action="/admin/coupons/<%= coupon._id %>/delete" method="POST" class="d-inline delete-form"
                        data-code="<%= coupon.code %>">
                        <button type="submit" class="action-btn delete-btn">
                          Delete
                        </button>
                      </form>
                    </td>
                  </tr>
                  <% }) %>
              </tbody>
            </table>
          </div>
          <% } else { %>
            <div class="no-coupons">
              <h4>No coupons found</h4>
              <p>Create your first coupon to get started.</p>
              <button type="button" class="create-btn mt-3" data-bs-toggle="modal" data-bs-target="#createCouponModal">
                Create Coupon
              </button>
            </div>
            <% } %>
  </div>
<div class="d-flex justify-content-center mt-4">
  <nav>
    <ul class="pagination">

     

      <!-- Page Numbers -->
      <% for(let i = 1; i <= totalPages; i++) { %>
        <li class="page-item <%= currentPage === i ? 'active' : '' %>">
          <a class="page-link" href="?page=<%= i %>"><%= i %></a>
        </li>
      <% } %>

     

    </ul>
  </nav>
</div>
  <!-- Create Coupon Modal -->
  <div class="modal fade" id="createCouponModal" tabindex="-1" aria-labelledby="createCouponModalLabel"
    aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="createCouponModalLabel">Create New Coupon</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>

        <form id="createCouponForm">
          <div class="modal-body">
            <div class="row g-3">
              <div class="col-md-6">
                <label for="create_code" class="form-label">Coupon Code <span class="text-danger">*</span></label>
                <input type="text" class="form-control text-uppercase" id="create_code" name="code"
                  placeholder="SUMMER25" maxlength="20">
                <div class="error-text" id="error_code"></div>
              </div>

              <div class="col-md-6">
                <label for="create_discountType" class="form-label">Discount Type <span
                    class="text-danger">*</span></label>
                <select class="form-select" id="create_discountType" name="discountType">
                  <option value="">Select type</option>
                  <option value="percentage">Percentage (%)</option>
                  <option value="flat">Flat Amount (₹)</option>
                </select>
                <div class="error-text" id="error_discountType"></div>
              </div>

              <div class="col-md-6">
                <label for="create_discountValue" class="form-label">Discount Value <span
                    class="text-danger">*</span></label>
                <input type="number" class="form-control" id="create_discountValue" name="discountValue" min="0.01"
                  step="0.01" placeholder="25 or 150">

                <div class="error-text" id="error_discountValue"></div>
              </div>

              <div class="col-md-6">
                <label for="create_minPurchase" class="form-label">Minimum Purchase (₹)</label>
                <input type="number" class="form-control" id="create_minPurchase" name="minPurchase" min="0" step="0.01"
                  value="0">

                <div class="error-text" id="error_minPurchase"></div>
              </div>

              <div class="col-md-6">
                <label for="create_maxDiscount" class="form-label">Maximum Discount Cap (₹) <small
                    class="text-muted">(for % only)</small></label>
                <input type="number" class="form-control" id="create_maxDiscount" name="maxDiscount" min="0"
                  step="0.01">

                <div class="error-text" id="error_maxDiscount"></div>
              </div>

              <div class="col-md-6">
                <label for="create_usageLimit" class="form-label">Usage Limit</label>
                <input type="number" class="form-control" id="create_usageLimit" name="usageLimit" min="1" value="1">

                <div class="error-text" id="error_usageLimit"></div>
              </div>

              <div class="col-md-6">
                <label for="create_expiryDate" class="form-label">Expiry Date <span class="text-danger">*</span></label>
                <input type="date" class="form-control" id="create_expiryDate" name="expiryDate">
              </div>
              <div class="error-text" id="error_expiryDate"></div>

              <div class="col-12">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="isActive" id="create_isActive" checked>
                  <label class="form-check-label" for="create_isActive">Coupon is active</label>
                </div>
              </div>
            </div>
          </div>

          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary">
              <i class="fas fa-save me-2"></i> Create Coupon
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Edit Coupon Modal -->
<div class="modal fade" id="editCouponModal" tabindex="-1" aria-labelledby="editCouponModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title" id="editCouponModalLabel">Edit Coupon</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <form id="editCouponForm" method="POST">
        <input type="hidden" name="_method" value="PUT">

        <div class="modal-body">
          <div class="row g-3">

            <!-- CODE -->
            <div class="col-md-6">
              <label class="form-label">Coupon Code *</label>
              <input type="text" id="edit_code" name="code" class="form-control">
              <div class="error-text" id="edit_error_code"></div>
            </div>

            <!-- TYPE -->
            <div class="col-md-6">
              <label class="form-label">Discount Type *</label>
              <select id="edit_discountType" name="discountType" class="form-select">
                <option value="">Select type</option>
                <option value="percentage">Percentage (%)</option>
                <option value="flat">Flat Amount (₹)</option>
              </select>
              <div class="error-text" id="edit_error_discountType"></div>
            </div>

            <!-- VALUE -->
            <div class="col-md-6">
              <label class="form-label">Discount Value *</label>
              <input type="number" id="edit_discountValue" name="discountValue" class="form-control">
              <div class="error-text" id="edit_error_discountValue"></div>
            </div>

            <!-- MIN PURCHASE -->
            <div class="col-md-6">
              <label class="form-label">Minimum Purchase (₹)</label>
              <input type="number" id="edit_minPurchase" name="minPurchase" class="form-control">
              <div class="error-text" id="edit_error_minPurchase"></div>
            </div>

            <!-- MAX DISCOUNT -->
            <div class="col-md-6">
              <label class="form-label">Max Discount (₹)</label>
              <input type="number" id="edit_maxDiscount" name="maxDiscount" class="form-control">
              <div class="error-text" id="edit_error_maxDiscount"></div>
            </div>

            <!-- USAGE -->
            <div class="col-md-6">
              <label class="form-label">Usage Limit *</label>
              <input type="number" id="edit_usageLimit" name="usageLimit" class="form-control">
              <div class="error-text" id="edit_error_usageLimit"></div>
            </div>

            <!-- EXPIRY -->
            <div class="col-md-6">
              <label class="form-label">Expiry Date *</label>
              <input type="date" id="edit_expiryDate" name="expiryDate" class="form-control">
              <div class="error-text" id="edit_error_expiryDate"></div>
            </div>

            <!-- ACTIVE -->
            <div class="col-12">
              <div class="form-check">
                <input type="checkbox" id="edit_isActive" name="isActive" class="form-check-input">
                <label class="form-check-label">Coupon is active</label>
              </div>
            </div>

          </div>
        </div>

        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">
            Update Coupon
          </button>
        </div>

      </form>
    </div>
  </div>
</div>


  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
    crossorigin="anonymous"></script>

  <script>
    document.getElementById("createCouponForm")
      .addEventListener("submit", async function (e) {

        e.preventDefault();

        let hasError = false;

        // clear
        document.querySelectorAll("#createCouponForm .error-text")
          .forEach(el => el.innerText = "");

        document.querySelectorAll("#createCouponForm input, #createCouponForm select")
          .forEach(el => el.classList.remove("input-error"));

        const data = Object.fromEntries(new FormData(this).entries());

        if (!data.code) {
          error("create_code", "error_code", "Required");
          hasError = true;
        }

        if (!data.discountType) {
          error("create_discountType", "error_discountType", "Select type");
          hasError = true;
        }

        if (!data.discountValue || data.discountValue <= 0) {
          error("create_discountValue", "error_discountValue", "Invalid value");
          hasError = true;
        }

        if (!data.usageLimit || data.usageLimit < 1) {
          error("create_usageLimit", "error_usageLimit", "Min 1");
          hasError = true;
        }

        if (!data.expiryDate) {
          error("create_expiryDate", "error_expiryDate", "Select date");
          hasError = true;
        }

        if (hasError) return;

        const res = await fetch("/admin/coupons/create", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data)
        });

        const result = await res.json();

        if (result.success) location.reload();
      });


    /* ================= EDIT ================= */

    document.getElementById("editCouponForm")
      .addEventListener("submit", function (e) {

        let hasError = false;

        document.querySelectorAll("#editCouponForm .error-text")
          .forEach(el => el.innerText = "");

        document.querySelectorAll("#editCouponForm input, #editCouponForm select")
          .forEach(el => el.classList.remove("input-error"));

        const code = edit_code.value.trim();
        const type = edit_discountType.value;
        const value = edit_discountValue.value;
        const usage = edit_usageLimit.value;
        const expiry = edit_expiryDate.value;

        if (!code) {
          error("edit_code", "edit_error_code", "Required");
          hasError = true;
        }

        if (!type) {
          error("edit_discountType", "edit_error_discountType", "Select type");
          hasError = true;
        }

        if (!value || value <= 0) {
          error("edit_discountValue", "edit_error_discountValue", "Invalid value");
          hasError = true;
        }

        if (!usage || usage < 1) {
          error("edit_usageLimit", "edit_error_usageLimit", "Min 1");
          hasError = true;
        }

        if (!expiry) {
          error("edit_expiryDate", "edit_error_expiryDate", "Select date");
          hasError = true;
        }

        if (hasError) e.preventDefault();
      });


    /* ================= COMMON FUNCTION ================= */

    function error(inputId, errorId, msg) {
      document.getElementById(inputId).classList.add("input-error");
      document.getElementById(errorId).innerText = msg;
    }
    // Uppercase for create modal
    document.getElementById('create_code')?.addEventListener('input', function () {
      this.value = this.value.toUpperCase().trim();
    });


    document.getElementById("createCouponForm")
      .addEventListener("submit", async function (e) {

        e.preventDefault();

        const formData = new FormData(this);
        const data = Object.fromEntries(formData.entries());

        const response = await fetch("/admin/coupons/create", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify(data)
        });

        const result = await response.json();

        if (result.success) {
          Swal.fire("Success", result.message, "success")
            .then(() => location.reload());
        } else {
          Swal.fire("Error", result.message, "error");
        }
      });
    // Populate edit modal when edit button is clicked
    document.querySelectorAll('.edit-btn').forEach(button => {
      button.addEventListener('click', function () {
        const modal = document.getElementById('editCouponModal');
        const form = document.getElementById('editCouponForm');

        // Set form action dynamically with coupon ID
        const couponId = this.getAttribute('data-id');
        form.action = `/admin/coupons/${couponId}/edit`;

        // Fill fields
        document.getElementById('edit_code').value = this.getAttribute('data-code') || '';
        document.getElementById('edit_discountType').value = this.getAttribute('data-type') || 'percentage';
        document.getElementById('edit_discountValue').value = this.getAttribute('data-value') || '';
        document.getElementById('edit_minPurchase').value = this.getAttribute('data-min') || '0';
        document.getElementById('edit_maxDiscount').value = this.getAttribute('data-max') || '';
        document.getElementById('edit_usageLimit').value = this.getAttribute('data-limit') || '1';
        document.getElementById('edit_expiryDate').value = this.getAttribute('data-expiry') || '';

        // Checkbox
        const isActive = this.getAttribute('data-active') === 'true';
        document.getElementById('edit_isActive').checked = isActive;

        // Optional: Uppercase live in edit too
        const editCodeInput = document.getElementById('edit_code');
        editCodeInput.addEventListener('input', function () {
          this.value = this.value.toUpperCase().trim();
        }, { once: true }); // only once per modal open
      });
    });

    document.getElementById("editCouponForm")
.addEventListener("submit", async function (e) {

  e.preventDefault();

  let hasError = false;

  // validation...
  if (hasError) return;

  const formData = new FormData(this);
  const data = Object.fromEntries(formData.entries());

  const actionUrl = this.action; 

  const response = await fetch(actionUrl, {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify(data)
  });

  const result = await response.json();

  if (result.success) {
    Swal.fire("Success", result.message, "success")
      .then(() => location.reload());
  } else {
    Swal.fire("Error", result.message, "error");
  }

});
    document.querySelectorAll(".delete-form").forEach(form => {
      form.addEventListener("submit", function (e) {
        e.preventDefault();

        const couponCode = this.getAttribute("data-code");

        Swal.fire({
          title: "Are you sure?",
          text: `Deactivate coupon ${couponCode}?`,
          icon: "warning",
          showCancelButton: true,
          confirmButtonColor: "#dc3545",
          cancelButtonColor: "#6c757d",
          confirmButtonText: "Yes, deactivate it!",
          cancelButtonText: "Cancel"
        }).then((result) => {
          if (result.isConfirmed) {
            this.submit();
          }
        });
      });
    });

  </script>

  <%- include("../../views/partials/admin/footer") %>