<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title><%= product ? 'Edit Product' : 'Add Product' %></title>
<link href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  /* Applied Titan watch store luxury aesthetic with dark theme and gold accents */
  body { 
    font-family: 'Inter', sans-serif; 
    background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 100%); 
    margin: 0; 
    padding: 0;
    color: #e5e5e5;
    min-height: 100vh;
  }
  
  .container { 
    width: 90%; 
    max-width: 900px; 
    margin: 30px auto; 
    background: rgba(26, 26, 26, 0.95); 
    padding: 40px 50px; 
    border-radius: 12px; 
    box-shadow: 0 8px 32px rgba(212, 175, 55, 0.1);
    border: 1px solid rgba(212, 175, 55, 0.2);
  }
  
  h2 { 
    text-align: center; 
    color: #d4af37; 
    margin-bottom: 30px;
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: 1px;
  }
  
  form label { 
    font-weight: 600; 
    display: block; 
    margin-top: 20px;
    color: #d4af37;
    font-size: 0.95rem;
    letter-spacing: 0.5px;
  }
  
  form input, form select, form textarea { 
    width: 100%; 
    padding: 12px 16px; 
    margin-top: 8px; 
    border: 1px solid rgba(212, 175, 55, 0.3); 
    border-radius: 6px; 
    font-size: 14px;
    background: rgba(15, 15, 15, 0.8);
    color: #e5e5e5;
    transition: all 0.3s ease;
    font-family: 'Inter', sans-serif;
  }
  
  form input:focus, form select:focus, form textarea:focus {
    outline: none;
    border-color: #d4af37;
    box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.1);
  }
  
  form textarea { 
    resize: vertical;
    min-height: 100px;
  }
  
  .variants-container { 
    margin-top: 30px; 
  }
  
  .variant { 
    border: 1px solid rgba(212, 175, 55, 0.3); 
    padding: 25px; 
    border-radius: 8px; 
    margin-bottom: 25px; 
    background: rgba(15, 15, 15, 0.6); 
    position: relative;
    transition: all 0.3s ease;
  }
  
  .variant:hover {
    border-color: rgba(212, 175, 55, 0.5);
    box-shadow: 0 4px 16px rgba(212, 175, 55, 0.1);
  }
  
  .variant h4 { 
    margin-top: 0; 
    color: #d4af37;
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    font-weight: 600;
  }
  
  .remove-variant-btn { 
    position: absolute; 
    top: 15px; 
    right: 15px; 
    background: #dc2626; 
    color: white; 
    border: none; 
    border-radius: 6px; 
    cursor: pointer; 
    padding: 8px 16px;
    font-weight: 500;
    transition: all 0.3s ease;
  }
  
  .remove-variant-btn:hover { 
    background: #b91c1c;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(220, 38, 38, 0.3);
  }
  
  button { 
    background: linear-gradient(135deg, #d4af37 0%, #f4d03f 100%); 
    color: #1a1a1a; 
    padding: 12px 24px; 
    border: none; 
    border-radius: 6px; 
    cursor: pointer; 
    font-size: 15px; 
    margin-top: 15px;
    font-weight: 600;
    transition: all 0.3s ease;
    letter-spacing: 0.5px;
  }
  
  button:hover { 
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(212, 175, 55, 0.4);
  }
  
  .add-variant-btn { 
    background: linear-gradient(135deg, #8b7355 0%, #6b5d4f 100%);
    color: #d4af37;
  }
  
  .add-variant-btn:hover { 
    box-shadow: 0 6px 20px rgba(139, 115, 85, 0.4);
  }
  
  .preview-box img, .final img { 
    max-width: 200px; 
    max-height: 200px; 
    border: 2px solid rgba(212, 175, 55, 0.3); 
    border-radius: 8px; 
    margin-top: 10px;
    transition: all 0.3s ease;
  }
  
  .preview-box img:hover, .final img:hover {
    border-color: #d4af37;
    box-shadow: 0 4px 16px rgba(212, 175, 55, 0.2);
  }
  
  .error-message { 
    color: #ef4444; 
    font-size: 0.85rem; 
    display: none;
    margin-top: 4px;
    font-weight: 500;
  }
  
  .image-container { 
    margin: 15px 0;
    padding: 15px;
    background: rgba(10, 10, 10, 0.5);
    border-radius: 8px;
    border: 1px solid rgba(212, 175, 55, 0.1);
  }
  
  .crop-btn, .edit-btn, .delete-btn { 
    margin: 8px 5px;
    padding: 8px 16px;
    font-size: 13px;
  }
  
  .edit-btn {
    background: linear-gradient(135deg, #6b5d4f 0%, #8b7355 100%);
    color: #d4af37;
  }
  
  .delete-btn {
    background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
    color: white;
  }
  
  input[type="checkbox"] {
    width: auto;
    margin-right: 8px;
    accent-color: #d4af37;
    cursor: pointer;
  }
  
  .image-preview {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 20px;
    margin-top: 15px;
  }
  
  input[type="file"] {
    background: rgba(10, 10, 10, 0.8);
    border: 2px dashed rgba(212, 175, 55, 0.3);
    cursor: pointer;
    padding: 20px;
  }
  
  input[type="file"]:hover {
    border-color: #d4af37;
  }
  
  select option {
    background: #1a1a1a;
    color: #e5e5e5;
  }
</style>
</head>
<body>
<div class="container">
  <h2><%= product ? 'Edit Product' : 'Add Product' %></h2>
  <form id="productForm" action="/admin/<%= product ? 'editproduct/'+product._id : 'addproduct' %>" method="POST" enctype="multipart/form-data" novalidate>
    
    <!-- Product Details -->
    <label for="product">Product Name</label>
    <input type="text" name="product" id="name" value="<%= product ? product.product : '' %>" placeholder="Enter product name" />
    <div id="errorName" class="error-message">Product name is required</div>

    <label for="brand">Brand</label>
    <select id="brand" name="brand">
      <option value="">--Select Brand--</option>
      <% brands.forEach(b => { %>
        <option value="<%= b._id %>" <%= product && product.brand && product.brand._id.toString() === b._id.toString() ? "selected" : "" %>><%= b.name %></option>
      <% }) %>
    </select>
    <div id="errorBrand" class="error-message">Please select a brand</div>

    <label for="description">Description</label>
    <textarea name="description" placeholder="Enter product description"><%= product ? product.description : '' %></textarea>

    <label for="strapMaterial">Strap Material</label>
    <select id="strapMaterial" name="strapMaterial">
      <option value="">--Select Strap Material--</option>
      <% ["leather", "rubber", "metal", "ceramics","silicon","steel"].forEach(material => { %>
        <option value="<%= material %>" <%= product && product.strapMaterial === material ? "selected" : "" %>><%= material.charAt(0).toUpperCase() + material.slice(1) %></option>
      <% }) %>
    </select>
    <div id="errorStrap" class="error-message">Please select a strap material</div>

    <label for="discount">Discount (%)</label>
    <input type="number" name="discount" placeholder="0" min="0" value="<%= product ? product.discount : '' %>" />
    <div id="errorDiscount" class="error-message">Discount is required</div>
    <label for="productOffer">Product Offer (%)</label>
    <input type="number" name="productOffer" placeholder="0" min="0" value="<%= product ? product.productOffer : '' %>" />
    <div id="errorProductOffer" class="error-message">Product offer is required</div>

    <label>Categories</label>
    <% categories.forEach(cat => { %>
      <input type="checkbox" name="categories[]" value="<%= cat._id %>"
        <%= product && product.categories && product.categories.map(c => c._id.toString()).includes(cat._id.toString()) ? 'checked' : '' %> />
      <%= cat.name %><br/>
    <% }) %>
    <div id="errorCategory" class="error-message">Please select at least one category</div>

<div id="variantsContainer">
  <% if(product && product.variants && product.variants.length){ %>
    <% product.variants.forEach(function(variant, vIndex){ %>
      <div class="variant" data-id="<%= variant._id %>">
        <h4>Variant <%= vIndex+1 %></h4>

        <label>Dial Color</label>
        <input type="text" name="dialColor[]" value="<%= variant.dialColor %>" placeholder="Dial Color" required />
        <div class="error-message">Dial color is required</div>

        <label>Strap Color</label>
        <input type="text" name="strapColor[]" value="<%= variant.strapColor %>" placeholder="Strap Color" required/>
        <div class="error-message">Strap color is required</div>

        <label>Price</label>
        <input type="number" name="price[]" value="<%= variant.price %>" placeholder="Price" min="0" required />
        <div class="error-message">Price is required</div>

        <label>Stock</label>
        <input type="number" name="stock[]" value="<%= variant.stock %>" placeholder="Stock" min="0" required/>
        <div class="error-message">Stock is required</div>

        <label>Images (Minimum 4)</label>
        <div class="image-preview">
          <% for(let i=0;i<4;i++){ %>
            <div class="image-container">
              <input type="file" class="img-input"  style="display:none" accept="image/*" />
              <div class="error-message">Image is required</div>
              <div class="preview-box">
                <% if(variant.images[i]){ %>
                  <img src="<%= variant.images[i].croppedUrl || variant.images[i].originalUrl %>" 
                       data-original-url="<%= variant.images[i].originalUrl %>"
                       data-cropped-url="<%= variant.images[i].croppedUrl %>"
                       data-original-filename="<%= variant.images[i].originalFileName %>"
                       data-cropped-filename="<%= variant.images[i].croppedFileName %>"
                       style="display:none;"
                       alt="">
                <% } else { %>
                  <img alt="">
                <% } %>
              </div>
              <button type="button" class="crop-btn" style="display:none;">Crop & Upload</button>
              <div class="final">
                <% if(variant.images[i]){ %>
                  <img src="<%= variant.images[i].croppedUrl || variant.images[i].originalUrl %>" 
                       data-original-url="<%= variant.images[i].originalUrl %>"
                       data-cropped-url="<%= variant.images[i].croppedUrl %>"
                       data-original-filename="<%= variant.images[i].originalFileName %>"
                       data-cropped-filename="<%= variant.images[i].croppedFileName %>"
                       alt="">
                  <button type="button" class="edit-btn">Edit</button>
                  <button type="button" class="delete-btn">Delete</button>
                <% } else { %>
                  <img alt="">
                  <button type="button" class="edit-btn" style="display:none;">Edit</button>
                  <button type="button" class="delete-btn" style="display:none;">Delete</button>
                <% } %>
              </div>
            </div>
          <% } %>
        </div>
      </div>
    <% }) %>
  <% } %>
</div>
<button type="button" class="add-variant-btn" onclick="addVariant()">+ Add Another Variant</button>
<br/>
<button type="submit"><%= product ? 'Update Product' : 'Add Product' %></button>
</form>
</div>

</body>
</html>


<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
let variantCount = <%= product && product.variants ? product.variants.length : 1 %>;
function validateImageFile(input) {
    const file = input.files[0];
    if (!file) return true;
    const allowedTypes = ["image/jpeg","image/png","image/webp"];
    if (!allowedTypes.includes(file.type)) {
       Swal.fire({ icon: 'error', text: 'Only JPG, PNG, or WEBP images are allowed. PDFs are not allowed.' });

        input.value = "";
        return false;
    }
    return true;
}
document.addEventListener("change", function (event) {
    if (event.target.classList.contains("img-input")) {
        
        
        const ok = validateImageFile(event.target);
        if (!ok) return; 

        
        event.target.dispatchEvent(new Event("valid-image"));
    }
});

// Setup Cropper
function setupCropper(input, preview, final, cropBtn) {
  const parent = final.parentElement;
  const editBtn = parent.querySelector(".edit-btn");
  const deleteBtn = parent.querySelector(".delete-btn");

  function bindCrop() {
    cropBtn.onclick = function() {
      if (!input.cropper) return;
      const canvas = input.cropper.getCroppedCanvas({ imageSmoothingQuality:'high' });
      canvas.toBlob(function(blob){
        input.croppedBlob = blob;
        final.src = URL.createObjectURL(blob);
        preview.style.display = "none";
        cropBtn.style.display = "none";
        input.style.display = "none";
        input.cropper.destroy();
        input.cropper = null;
        editBtn.style.display = "inline-block";
        deleteBtn.style.display = "inline-block";
      }, "image/jpeg");
    };
  }

  input.addEventListener("valid-image", function(){
    const file = input.files[0];
    if(!file) return;
    preview.src = URL.createObjectURL(file);
    preview.style.display = "block";

    if(input.cropper) input.cropper.destroy();
    input.cropper = new Cropper(preview, {aspectRatio:1, viewMode:2});
    cropBtn.style.display = "inline-block";
    bindCrop();
  });
}

// Handle edit/delete buttons
document.addEventListener("click", function(e){
  const container = e.target.closest(".image-container");
  if(!container) return;

  const input = container.querySelector(".img-input");
  const preview = container.querySelector(".preview-box img");
  const final = container.querySelector(".final img");
  const cropBtn = container.querySelector(".crop-btn");
  const editBtn = container.querySelector(".edit-btn");
  const deleteBtn = container.querySelector(".delete-btn");

  if(e.target.classList.contains("edit-btn")){
    const originalUrl = final.dataset.originalUrl 
    preview.src = originalUrl;
    preview.style.display = "block";
    editBtn.style.display = "none";
    deleteBtn.style.display = "none";

    if(input.cropper) input.cropper.destroy();
    input.cropper = new Cropper(preview, {aspectRatio:1, viewMode:2});
    cropBtn.style.display = "inline-block";

    cropBtn.onclick = function(){
      const canvas = input.cropper.getCroppedCanvas({ imageSmoothingQuality:'high' });
      canvas.toBlob(function(blob){
        input.croppedBlob = blob;
        final.src = URL.createObjectURL(blob);
        preview.style.display = "none";
        cropBtn.style.display = "none";
        input.style.display = "none";
        input.cropper.destroy();
        input.cropper = null;
        editBtn.style.display = "inline-block";
        deleteBtn.style.display = "inline-block";
      }, "image/jpeg");
    };
  }

  if(e.target.classList.contains("delete-btn")){
    input.value = "";
    input.croppedBlob = null;
    final.src = "";
    final.dataset.originalUrl = "";  // ✅ clear DB reference
    final.dataset.croppedUrl = "";

    preview.src = "";
    preview.style.display = "none";
    editBtn.style.display = "none";
    deleteBtn.style.display = "none";
    input.style.display = "block";
    cropBtn.style.display = "none";

    if(input.cropper) input.cropper.destroy();
  }
});

// Add new variant
function addVariant(){
  variantCount++;
  const container = document.getElementById("variantsContainer");
  const div = document.createElement("div");
  div.className = "variant";
  div.innerHTML = `
    <button type="button" class="remove-variant-btn">Remove Variant</button>
    <h4>Variant ${variantCount}</h4>
    <label>Dial Color</label>
    <input type="text" name="dialColor[]" placeholder="Dial Color" required/><div class="error-message"></div>
    <label>Strap Color</label>
    <input type="text" name="strapColor[]" placeholder="Strap Color" required/><div class="error-message"></div>
    <label>Price</label>
    <input type="number" name="price[]" placeholder="Price" min="0" required/><div class="error-message"></div>
    <label>Stock</label>
    <input type="number" name="stock[]" placeholder="Stock" min="0"/><div class="error-message"></div>
    <label>Images (Minimum 4)</label>
    <div class="image-preview">
      ${[1,2,3,4].map(i=>`
        <div class="image-container">
          <input type="file" class="img-input" accept="image/*"/>
          <div class="error-message"></div>
          <div class="preview-box"><img alt=""></div>
          <button type="button" class="crop-btn" style="display:none;">Crop & Upload</button>
          <div class="final">
            <img alt="">
            <button type="button" class="edit-btn" style="display:none;">Edit</button>
            <button type="button" class="delete-btn" style="display:none;">Delete</button>
          </div>
        </div>
      `).join('')}
    </div>
  `;
  container.appendChild(div);

  // Setup cropper for new variant images
  div.querySelectorAll(".image-container").forEach(ic=>{
    const input = ic.querySelector(".img-input");
    const preview = ic.querySelector(".preview-box img");
    const final = ic.querySelector(".final img");
    const cropBtn = ic.querySelector(".crop-btn");
    setupCropper(input, preview, final, cropBtn);
  });

  // Remove variant
  div.querySelector(".remove-variant-btn").addEventListener("click", ()=>{
    div.remove();
  });
}

// Initialize existing variant images
document.querySelectorAll(".variant").forEach((variant, vIndex)=>{
  const imgContainers = variant.querySelectorAll(".image-container");
  imgContainers.forEach((ic, iIndex)=>{
    const input = ic.querySelector(".img-input");
    const preview = ic.querySelector(".preview-box img");
    const final = ic.querySelector(".final img");
    const cropBtn = ic.querySelector(".crop-btn");
    setupCropper(input, preview, final, cropBtn);
  });
});



    // Form validation
   // ==================== FORM VALIDATION =====================
const productId = "<%= product._id %>";
const form = document.getElementById("productForm");
const name = document.getElementById("name");
const er1 = document.getElementById("errorName");
const brand = document.getElementById("brand");
const er2 = document.getElementById("errorBrand");
const categories = document.querySelectorAll('input[name="categories[]"]');
const strap = document.getElementById("strapMaterial");
const er3 = document.getElementById("errorStrap");
const discountInput = document.querySelector('input[name="discount"]');
const offerInput = document.querySelector('input[name="productOffer"]');
const errorDiscount = document.getElementById('errorDiscount');
const errorOffer = document.getElementById('errorProductOffer');
 


function scrollToError() {
  const firstError = document.querySelector(".error-message[style*='block']");
  if (firstError) {
    
    setTimeout(() => {
      firstError.scrollIntoView({ behavior: "smooth", block: "center" });
    }, 50);
  }
}

function validateProductName() {
  const value = name.value.trim();
if (value === "") {
    er1.textContent = "Product name is required";
    er1.style.display = "block";
    return false;
  } else if (value.length < 3) {
    er1.textContent = "Name must be at least 3 characters";
    er1.style.display = "block";
    return false;
  }else if (!/[A-Za-z]/.test(value)) {
        er1.textContent="Name must contain at least one letter";
        er1.style.display = "block";
        return false;
    }
  else if (!/^[A-Za-z0-9\s\-\&\.\,\*\!\@\#\$\%\^\_]+$/.test(value))
 {
    er1.textContent ="Only letters, numbers, spaces, and - & . , * ! @ # $ % ^ _ are allowed";
    er1.style.display = "block";
    return false;
  }else  if (/^([A-Za-z])\1+$/.test(value)) {
  er1.textContent = "Name cannot be made of a single repeated letter";
  er1.style.display = "block";
  return false;
  }else {
    er1.style.display = "none";
    return true;
  }
}

function validateBrand() {
  if (brand.value === "") {
    er2.textContent = "Please select a brand";
    er2.style.display = "block";
    return false;
  } else {
    er2.style.display = "none";
    return true;
  }
}

function validateCategory() {
  let selected = false;
  for (let i = 0; i < categories.length; i++) {
    if (categories[i].checked) {
      selected = true;
      break;
    }
  }
  if (!selected) {
    document.getElementById("errorCategory").textContent =
      "Please select at least one category";
    document.getElementById("errorCategory").style.display = "block";
    return false;
  } else {
    document.getElementById("errorCategory").style.display = "none";
    return true;
  }
}

function strapValidate() {
  if (strap.value.trim() === "") {
    er3.textContent = "Strap material is required";
    er3.style.display = "block";
    return false;
  } else {
    er3.style.display = "none";
    return true;
  }
}



function validateDiscount() {
    const value = Number(discountInput.value);
    if (discountInput.value === "") {
        errorDiscount.style.display = "none"; // optional
        return true;
    } else if (isNaN(value) || value < 0 || value > 100) {
        errorDiscount.textContent = "Discount must be between 0 and 100";
        errorDiscount.style.display = "block";
        return false;
    } else {
        errorDiscount.style.display = "none";
        return true;
    }
}

function validateOffer() {
    const value = Number(offerInput.value);
    if (offerInput.value === "") {
        errorOffer.style.display = "none"; 
        return true;
    } else if (isNaN(value) || value < 0 || value > 100) {
        errorOffer.textContent = "Product Offer must be between 0 and 100";
        errorOffer.style.display = "block";
        return false;
    } else {
        errorOffer.style.display = "none";
        return true;
    }
}

function isValidColorName(value) {
  const colors = [
    "black","white","blue","brown","green","silver","gold",
    "rose gold","grey","red","cream","beige","navy","tan"
  ];

  const clean = value.trim().toLowerCase();
  return colors.includes(clean);
}


