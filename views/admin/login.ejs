<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login</title>
     <link href="https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@300;400;600;700;800;900&display=swap"
   rel="stylesheet">
   <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
       <link href="/admin-assets/css/main.css" rel="stylesheet" type="text/css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@10.16.6/dist/sweetalert2.min.css">
<script src="https://kit.fontawesome.com/16d4885483.js" crossorigin="anonymous"></script>
<script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>

   
    <style>
        body {
            font-family: Arial, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            background-color: #000;
            color: #fff;
        }
        .login-container {
            background-color: #1a1a1a;
            padding: 40px;
            border-radius: 10px;
            text-align: center;
            width: 300px;
        }
        .logo {
            font-size: 40px;
            font-weight: bold;
            margin-bottom: 20px;
        }
        .logo {
            margin-bottom: 20px;
        }
        .logo img {
            width: 100px;
        }
        .form-group {
            margin-bottom: 15px;
            text-align: left;
        }
        .form-group label {
            display: block;
            margin-bottom: 5px;
            font-size: 14px;
        }
        .form-group input {
            width: 100%;
            padding: 10px;
            border: none;
            border-radius: 5px;
            background-color: #333;
            color: #fff;
        }
        .login-btn {
            width: 100%;
            padding: 8px; /* Reduced padding for smaller button */
            background-color: #fff;
            color: #000;
            border: none;
            border-radius: 5px;
            font-weight: bold;
            cursor: pointer;
        }
        .login-btn:hover {
            background-color: #ddd;
        }
        .footer {
            font-size: 12px;
            margin-top: 20px;
            color: #888;
        }
       
         .error {
      color: red;
      font-size: 12px;
      margin-top: 5px;
      display: none;
    }
    </style>
</head>
<body>
     
    <div class="login-container">
       <div class="logo">
            <img src="/img/adminlogo (2).png"alt="Wriston Logo">
        </div>
        <h2>Admin Login</h2>
       <form id="form1" action="/admin/login" method="post" novalidate>

            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" >
                <div class="error" id="error1"></div>
                
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" >
                <div class="error" id="error2"></div>

            </div>
            <div class="error">
              <%= typeof error !== "undefined" ? error : "" %>
             </div>

            <button type="submit" class="login-btn">Login</button>
        </form>
        <div class="footer">© 2025 wriston. All Rights Reserved.</div>
    </div>

<script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@10.16.6/dist/sweetalert2.all.min.js"></script>

<script>
    let form=document.getElementById("form1")
    let emailId=document.getElementById("email")
    let passId=document.getElementById("password")
     const er1 = document.getElementById("error1");
    const er2= document.getElementById("error2");

    function emailValidate(){

    const emailval = emailId.value.trim();
    const emailpattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/ ;
    if (emailval === "") {
      er1.style.display = "block";
      er1.innerHTML = "Email is required";
      return false;
    } else if (!emailpattern.test(emailval)) {
      er1.style.display = "block";
      er1.innerHTML = "Invalid email format";
      return false;
    } else {
      er1.style.display = "none";
      return true;
    }
  }


  function passwordValidate() {
    const passval = passId.value.trim();
     const passwordRegex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[\W_]).{8,}$/;
    if (passval === "") {
      er2.style.display = "block";
      er2.innerHTML = "Password is required";
      return false;
    } else if (!passwordRegex.test(passval)) {
    er2.style.display = "block";
    er2.innerHTML =
      "Password must be at least 8 characters and include uppercase, lowercase, number, and special character";
    return false;
    } else {
      er2.style.display = "none";
      return true;
    }
  }
form.addEventListener('submit', function(e) {
  let valid = true;
if (!emailValidate()) 
  valid = false;
  if (!passwordValidate()) 
  
  valid = false;
  

    if (!valid) {
    e.preventDefault(); 
  }
})

const errorMsg = "<%= typeof error !== 'undefined' ? error : '' %>";
if (errorMsg) Swal.fire("Error", errorMsg, "error");

const successMsg = "<%= typeof success !== 'undefined' ? success : '' %>";
if (successMsg) Swal.fire("Success", successMsg, "success");
</script>


    
</body>
</html>
