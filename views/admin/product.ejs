  .search-bar input {
    width: 100%;
    padding: 0.8rem 1rem 0.8rem 2.5rem;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    font-size: 1rem;
    transition: all 0.3s ease;
