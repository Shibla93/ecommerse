  /* Variant modal cards */
  .variant-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    margin-bottom: 1rem;
    background: #fdfdfd;
    box-shadow: var(--shadow-md);
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .variant-card strong {
    color: var(--color-gold);
    font-size: 1.1rem;
  }

  .no-products {
    text-align: center;
    padding: 6rem 2rem;
    background: var(--color-card-bg);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }

  .no-products h4 {
    font-size: 1.8rem;
    color: var(--color-dark);
    margin-bottom: 1rem;
  }
/* Variant count + view button spacing */
.variant-badge {
  margin-right: 12px;   /* creates gap */
}

.view-variants-btn {
  margin-top: 6px;
     /* optional: vertical balance */
}

  @media (max-width: 992px) {
    .container {
      margin: 100px auto 80px;
