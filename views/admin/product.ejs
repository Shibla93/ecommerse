<%- include("../../views/partials/admin/header") %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Product Table</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <style>
    body { 
      font-family: 'Inter', sans-serif; 
      background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%); 
      margin: 0; 
      padding: 0; 
      color: #e0e0e0;
    }
    .container { 
      width: 95%; 
      margin: 30px auto; 
      background: #1f1f1f; 
      padding: 30px 40px; 
      border-radius: 12px; 
      box-shadow: 0 8px 32px rgba(0,0,0,0.4);
      border: 1px solid #333;
    }
    h1 { 
      text-align: center; 
      margin-bottom: 30px; 
      font-family: 'Playfair Display', serif;
      font-weight: 600;
      font-size: 2.5rem;
      color: #d4af37;
      letter-spacing: 1px;
    }
    #searchInput { 
      width: 100%; 
      max-width: 400px; 
      margin: 0 auto 30px auto; 
      padding: 12px 20px; 
      border-radius: 25px; 
      border: 1px solid #444; 
      display: block; 
      font-size: 16px;
      background: #0f0f0f;
      color: #fcfcfc;
      transition: all 0.3s ease;
    }
    #searchInput:focus {
      outline: none;
      border-color: #d4af37;
      box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.1);
    }

    table { 
      width: 100%; 
      border-collapse: collapse; 
      margin-top: 20px;
    }
    th, td { 
      padding: 16px; 
      border: 1px solid #333; 
      vertical-align: middle; 
      text-align: left;
    }
    th { 
      background: linear-gradient(135deg, #2a2a2a 0%, #1a1a1a 100%); 
      color: #b7b724; 
      font-family: 'Playfair Display', serif;
      font-weight: 600;
      font-size: 1rem;
      letter-spacing: 0.5px;
      text-transform: uppercase;
    }
    td {
      background: #1f1f1f;
      color: #c0c0c0;
    }
    tr:hover td {
      background: #87c03c;
    }
    img.thumbnail { 
      width: 60px; 
      height: 60px; 
      object-fit: cover; 
      border-radius: 8px; 
      border: 2px solid #d4af37;
    }
    
    /* Updated button styles for luxury aesthetic */
    .btn {
      border: none;
      padding: 8px 20px;
      border-radius: 6px;
      font-weight: 500;
      transition: all 0.3s ease;
      font-size: 0.9rem;
    }
    .btn-primary {
      background: linear-gradient(135deg, #d4af37 0%, #b8941f 100%);
      color: #1a1a1a;
    }
    .btn-primary:hover {
      background: linear-gradient(135deg, #e6c558 0%, #d4af37 100%);
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(212, 175, 55, 0.3);
    }
    .btn-success {
      background: #2d5016;
      color: #a8d888;
    }
    .btn-success:hover {
      background: #3d6a1f;
      transform: translateY(-2px);
    }
    .btn-danger {
      background: #5a1a1a;
      color: #ff6b6b;
    }
    .btn-danger:hover {
      background: #7a2424;
      transform: translateY(-2px);
    }
    
    /* Badge for variant count */
    .variant-badge {
      display: inline-block;
      background: linear-gradient(135deg, #d4af37 0%, #b8941f 100%);
      color: #1a1a1a;
      padding: 6px 16px;
      border-radius: 20px;
      font-weight: 600;
      font-size: 0.95rem;
      margin-right: 10px;
    }
    
    /* Modal styles for variant viewer */
    .modal-content {
      background: #1f1f1f;
      border: 1px solid #444;
      color: #e0e0e0;
    }
    .modal-header {
      border-bottom: 1px solid #444;
      background: linear-gradient(135deg, #2a2a2a 0%, #1a1a1a 100%);
    }
    .modal-title {
      color: #d4af37;
      font-family: 'Playfair Display', serif;
      font-weight: 600;
    }
    .modal-footer {
      border-top: 1px solid #444;
    }
    .btn-close {
      filter: invert(1);
    }
    
    /* Variant card in modal */
    .variant-card {
      background: #2a2a2a;
      border: 1px solid #444;
      border-radius: 8px;
      padding: 15px;
      margin-bottom: 15px;
      transition: all 0.3s ease;
    }
    .variant-card:hover {
      border-color: #d4af37;
      box-shadow: 0 4px 16px rgba(212, 175, 55, 0.1);
    }
    .variant-card strong {
      color: #d4af37;
      font-size: 1.1rem;
    }
    
    .pagination .page-link {
      background: #2a2a2a;
      border: 1px solid #444;
      color: #d4af37;
      margin: 0 3px;
      border-radius: 6px;
    }
    .pagination .page-link:hover {
      background: #d4af37;
      color: #1a1a1a;
      border-color: #d4af37;
    }
    .pagination .page-item.active .page-link {
      background: linear-gradient(135deg, #d4af37 0%, #b8941f 100%);
      color: #1a1a1a;
      border-color: #d4af37;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>Product Management</h1>
<input 
  type="text" 
  id="searchInput" 
  placeholder="Search products..."
  value="<%= search %>"
/>


    <table class="table table-striped table-hover mt-3">
      <thead>
        <tr>
          <th>Product Name</th>
          <th>Strap Material</th>
          <th>Categories</th>
          <th>Brand</th>
          <th>Variants</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% products.forEach(product => { %>
          <tr>
            <td><%= product.product %></td>
            <td><%= product.strapMaterial || 'N/A' %></td>
            <td><%= product.categories && product.categories.length ? product.categories.map(c=>c.name).join(', ') : 'N/A' %></td>
            <td><%= product.brand %></td>
            <!-- Show variant count and view button instead of listing all variants -->
            <td>
              <span class="variant-badge"><%= product.variants.length %> Variant<%= product.variants.length !== 1 ? 's' : '' %></span>
              <button class="btn btn-primary btn-sm view-variants-btn" 
                      data-productid="<%= product._id %>" 
                      data-productname="<%= product.product %>">
                <i class="bi bi-eye"></i> View
              </button>
            </td>

            <td>
              <button class="btn btn-success edit-btn" data-productid="<%= product._id %>">
                <i class="bi bi-pencil"></i> Edit
              </button>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>

    <!-- Hidden data storage for variants -->
    <script id="productVariantsData" type="application/json">
      <%- JSON.stringify(products.map(p => ({
        _id: p._id,
        product: p.product,
        variants: p.variants
      }))) %>
    </script>
  </div>
  
  <div class="d-flex justify-content-center mt-3">
    <ul class="pagination">
      <% for (let i = 1; i <= totalPages; i++) { %>
        <li class="page-item <%= currentPage === i ? 'active' : '' %>">
          <a class="page-link" href="/admin/product?page=<%= i %>&search=<%= search %>"><%= i %></a>
        </li>
      <% } %>
    </ul>
  </div>

  <!-- Modal for viewing variants -->
  <div class="modal fade" id="variantsModal" tabindex="-1" aria-labelledby="variantsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="variantsModalLabel">Product Variants</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body" id="variantsModalBody">
          <!-- Variants will be loaded here -->
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        </div>
      </div>
    </div>
  </div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  // Load product data
  const productsData = JSON.parse(document.getElementById('productVariantsData').textContent);

  // Search
  document.getElementById("searchInput").addEventListener("keyup", function (e) {
  if (e.key === "Enter") {
    const value = this.value.trim();
    window.location.href = `/admin/product?search=${encodeURIComponent(value)}`;
  }
});

  document.querySelectorAll('.view-variants-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      const productId = this.dataset.productid;
      const productName = this.dataset.productname;
      const product = productsData.find(p => p._id === productId);
      
      if (!product) return;
      
      document.getElementById('variantsModalLabel').textContent = `Variants - ${productName}`;
      
      let html = '';
      product.variants.forEach(variant => {
        const imageUrl = (variant.images?.[0]?.croppedUrl || variant.images?.[0]?.originalUrl || '');
        html += `
          <div class="variant-card">
            <div class="row align-items-center">
              <div class="col-md-2">
                ${imageUrl ? `<img src="${imageUrl}" class="thumbnail" alt="Variant">` : '<span style="color:#888;">No Image</span>'}
              </div>
              <div class="col-md-6">
                <strong>
                  ${variant.dialColor ? variant.dialColor + ' Dial ' : ''}
                  ${variant.strapColor ? variant.strapColor + ' Strap' : ''}
                </strong>
                <br>
                <span style="color: #a0a0a0;">Price: ₹${variant.price.toFixed(2)} | Stock: ${variant.stock}</span>
              </div>
              <div class="col-md-4 text-end">
                ${variant.isListed 
                  ? `<button class="btn btn-success btn-sm list-btn" data-productid="${productId}" data-variantid="${variant._id}">Unlist</button>`
                  : `<button class="btn btn-danger btn-sm list-btn" data-productid="${productId}" data-variantid="${variant._id}">List</button>`
                }
                <button class="btn btn-danger btn-sm delete-btn" data-productid="${productId}" data-variantid="${variant._id}">
                  <i class="bi bi-trash"></i> Delete
                </button>
              </div>
            </div>
          </div>
        `;
      });
      
      document.getElementById('variantsModalBody').innerHTML = html;
      
      // Re-attach event listeners for buttons in modal
      attachVariantButtonListeners();
      
      new bootstrap.Modal(document.getElementById('variantsModal')).show();
    });
  });

  function attachVariantButtonListeners() {
    // List/Unlist variant
    document.querySelectorAll('.list-btn').forEach(btn => {
      btn.addEventListener('click', async function() {
        const productId = this.dataset.productid;
        const variantId = this.dataset.variantid;
        try {
          const res = await fetch(`/admin/product/list/${productId}/${variantId}`, {
            method: 'PATCH', 
            headers: {'Content-Type': 'application/json'}
          });
          const data = await res.json();
          if (data.success) {
            if (data.message === "listed") {
              this.textContent = "Unlist"; 
              this.classList.remove("btn-danger"); 
              this.classList.add("btn-success");
            } else {
              this.textContent = "List"; 
              this.classList.remove("btn-success"); 
              this.classList.add("btn-danger");
            }
          } else {
            Swal.fire("Error", data.message, "error");
          }
        } catch (err) {
          Swal.fire("Error", "Something went wrong!", "error");
        }
      });
    });

    // Delete variant
    document.querySelectorAll('.delete-btn').forEach(btn => {
      btn.addEventListener('click', async function() {
        const productId = this.dataset.productid;
        const variantId = this.dataset.variantid;
        const confirm = await Swal.fire({
          title: 'Are you sure?', 
          text: 'Delete this variant?', 
          icon: 'warning',
          showCancelButton: true, 
          confirmButtonColor: '#dc3545', 
          cancelButtonColor: '#6c757d', 
          confirmButtonText: 'Yes, delete!'
        });
        if (!confirm.isConfirmed) return;
        try {
          const res = await fetch(`/admin/product/delete/${productId}/${variantId}`, {
            method: 'PATCH', 
            headers: {'Content-Type': 'application/json'}
          });
          const data = await res.json();
          if (data.success) {
            this.closest('.variant-card').remove();
            Swal.fire("Deleted!", data.message, "success");
            // Reload page to update variant count
            setTimeout(() => location.reload(), 1500);
          } else {
            Swal.fire("Error", data.message, "error");
          }
        } catch (err) {
          Swal.fire("Error", "Something went wrong!", "error");
        }
      });
    });
  }

  // Edit product
  document.querySelectorAll('.edit-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      const productId = this.dataset.productid;
      window.location.href = `/admin/product/edit/${productId}`;
    });
  });
</script>
</body>
</html>
