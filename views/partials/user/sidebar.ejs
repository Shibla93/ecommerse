<style>
    /* ===== MODERN SIDEBAR BASE - UPDATED FOR LUXURY FEEL ===== */
    .sidebar {
      position: fixed;
      left: 0;
      top: 0;
      width: 250px; /* Slightly wider for elegance */
      height: 100vh;
      background: linear-gradient(180deg, #000000 0%, #1a1a1a 100%); /* Deep black gradient for premium luxury */
      color: #f0f0f0;
      display: flex;
      flex-direction: column;
      padding: 30px 0;
      box-shadow: 8px 0 30px rgba(0, 0, 0, 0.5);
      transition: transform 0.5s cubic-bezier(0.77, 0, 0.175, 1);
      z-index: 999;
      font-family: "Helvetica Neue", Helvetica, Arial, sans-serif; /* Cleaner, modern font */
    }

    .sidebar-header {
      text-align: center;
      margin-bottom: 60px;
      padding: 0 30px;
    }

    .sidebar-header h3 {
      font-size: 32px;
      font-weight: 300; /* Lighter weight for sophistication */
      color: #d4af37; /* Retained gold for Titan branding */
      letter-spacing: 4px;
      margin: 0;
      text-transform: uppercase;
    }

    .tagline {
      font-size: 14px;
      color: #a0a0a0;
      margin-top: 8px;
      letter-spacing: 2px;
      font-weight: 300;
    }

    .sidebar-menu {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 8px;
      padding: 0 30px;
    }

    .sidebar-menu a {
      color: #e0e0e0;
      text-decoration: none;
      font-size: 16px;
      padding: 16px 20px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      gap: 16px;
      transition: all 0.4s ease;
      position: relative;
      overflow: hidden;
    }

    .sidebar-menu a::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      width: 4px;
      height: 100%;
      background: #d4af37;
      transform: translateX(-100%);
      transition: transform 0.4s ease;
    }

    .sidebar-menu a i {
      font-size: 20px;
      width: 28px;
      transition: color 0.4s ease;
    }

    .sidebar-menu a:hover {
      background: rgba(212, 175, 55, 0.1);
      color: #d4af37;
      padding-left: 28px; /* Subtle indent on hover */
    }

    .sidebar-menu a:hover::before {
      transform: translateX(0);
    }

    .sidebar-menu a:hover i {
      color: #d4af37;
    }

    .active-link {
      background: rgba(212, 175, 55, 0.2) !important;
      color: #d4af37 !important;
      font-weight: 500;
      padding-left: 28px;
    }

    .active-link::before {
      transform: translateX(0);
    }

    .active-link i {
      color: #d4af37;
    }

    .logout-link {
      color: #ff6b6b !important;
      margin-top: auto;
      border-top: 1px solid rgba(255, 255, 255, 0.05);
      padding-top: 30px;
    }

    .logout-link:hover {
      background: rgba(255, 107, 107, 0.1) !important;
      color: #ff6b6b !important;
      padding-left: 28px;
    }

    /* ===== SIDEBAR TOGGLE FOR MOBILE ===== */
    .sidebar-toggle {
      display: none;
      position: fixed;
      top: 20px;
      left: 20px;
      font-size: 28px;
      color: #ffffff;
      background: rgba(0, 0, 0, 0.6);
      backdrop-filter: blur(10px);
      width: 50px;
      height: 50px;
      border-radius: 50%;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
      z-index: 1001;
      transition: all 0.3s ease;
    }

    .sidebar-toggle:hover {
      background: #d4af37;
      color: #000000;
    }
.main-content {
  min-height: 100vh;
  background-color: #f8f8f8;
  margin-left: 300px;
  transition: margin-left 0.5s cubic-bezier(0.77, 0, 0.175, 1);
}


   @media (max-width: 991px) {
  .main-content {
    margin-left: 0;
  }
}


      .sidebar.show {
        transform: translateX(0);
      }

      .sidebar-toggle {
        display: flex;
      }

      .container {
        margin-left: 0;
      }
    
</style>

<!-- Sidebar Navigation -->
<div class="sidebar">
    <div class="sidebar-header">
        <!-- <h3> WRISTON</h3>
        <p class="tagline">Timeless Elegance</p> -->
    </div>
    
    <nav class="sidebar-menu">
        <a href="/userProfile" class="<%= typeof activePage !== 'undefined' && activePage === 'profile' ? 'active-link' : '' %>">
            <i class="fas fa-user"></i> Account Details
        </a>
        <a href="/address" class="<%= typeof activePage !== 'undefined' && activePage === 'address' ? 'active-link' : '' %>">
            <i class="fas fa-map-marker-alt"></i> Address
        </a>
        <a href="/orders" class="<%= typeof activePage !== 'undefined' && activePage === 'orders' ? 'active-link' : '' %>">
            <i class="fas fa-shopping-bag"></i> Orders
        </a>
        <a href="/wallet" class="<%= typeof activePage !== 'undefined' && activePage === 'wallet' ? 'active-link' : '' %>">
            <i class="fas fa-wallet"></i> Wallet
        </a>
        <a href="/logout" class="logout-link">
            <i class="fas fa-sign-out-alt"></i> Logout
        </a>
    </nav>
</div>

