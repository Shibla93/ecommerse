<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Forgot Password • WRISTON</title>

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

  
  <style>
    :root {
      --black: #000000;
      --white: #ffffff;
      --gold: #d4af37;
      --border: #e5e5e5;
      --error: #c0392b;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Montserrat', sans-serif;
      background: var(--white);
      color: var(--black);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    .wriston-card {
      background: white;
      max-width: 480px;
      width: 100%;
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 20px 60px rgba(0,0,0,0.08);
    }

    .wriston-header {
      background: linear-gradient(rgba(0,0,0,0.75), rgba(0,0,0,0.75)),
                  url('https://img.freepik.com/premium-photo/two-luxury-watches-dark-reflective-surface-with-bokeh-background_14117-707786.jpg') center/cover no-repeat;
      color: white;
      text-align: center;
      padding: 50px 30px;
    }

    .wriston-logo-img {
      height: 70px;
      width: auto;
      margin-bottom: 20px;
    }

    .wriston-header h1 {
      font-family: 'Playfair Display', serif;
      font-size: 36px;
      font-weight: 800;
      letter-spacing: 1px;
      margin-bottom: 8px;
    }

    .wriston-header p {
      font-size: 15px;
      opacity: 0.9;
      font-weight: 500;
    }

    .form-body {
      padding: 50px 40px;
    }

    label {
      font-weight: 600;
      font-size: 14px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #333;
      margin-bottom: 10px;
      display: block;
    }

    input {
      width: 100%;
      padding: 16px 18px;
      border: 2px solid #ddd;
      border-radius: 8px;
      font-size: 16px;
      margin-bottom: 6px;
      transition: all 0.3s;
    }

    input:focus {
      outline: none;
      border-color: var(--gold);
      box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.15);
    }

    input.error {
      border-color: var(--error);
    }

    .error-message {
      color: var(--error);
      font-size: 13px;
      margin-top: 4px;
      margin-bottom: 10px;
      display: none;
    }

    .btn-wriston {
      width: 100%;
      padding: 18px;
      background: var(--black);
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 16px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      cursor: pointer;
      transition: all 0.3s;
      margin-top: 20px;
    }

    .btn-wriston:hover {
      background: #1a1a1a;
      transform: translateY(-2px);
    }

    .footer-text {
      text-align: center;
      margin-top: 30px;
      font-size: 14px;
      color: #666;
    }

    .footer-text a {
      color: var(--black);
      font-weight: 600;
      text-decoration: none;
    }

    .footer-text a:hover {
      color: var(--gold);
    }

    @media (max-width: 480px) {
      .wriston-header { padding: 40px 20px; }
      .wriston-header h1 { font-size: 32px; }
      .form-body { padding: 40px 30px; }
    }
  </style>
</head>
<body>

  <div class="wriston-card">
    <div class="wriston-header">
      <h1>Forgot Password</h1>
      <p>We'll send an OTP to reset your password</p>
    </div>

    <div class="form-body">
      <form id="forgotform" method="POST" action="/forgotpass" novalidate>
        <div>
          <label>Email Address</label>
          <input type="email" name="email" id="email" placeholder="you@example.com" required />
          <div id="error1" class="error-message"></div>
        </div>

        <button type="submit" class="btn-wriston">Send OTP</button>
      </form>

      <div class="footer-text">
        Remember your password? <a href="/login">Sign In</a>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <!-- Server-side error handling with nice SweetAlert -->
  <% if (typeof error !== 'undefined' && error.length > 0) { %>
    <script>
      Swal.fire({
        icon: 'error',
        title: 'Oops...',
        text: '<%= error %>',
        confirmButtonColor: '#d4af37',
        background: '#fff',
        color: '#000'
      });
    </script>
  <% } %>

  <!-- Success message (if you send one from backend) -->
  <% if (typeof success !== 'undefined' && success) { %>
    <script>
      Swal.fire({
        icon: 'success',
        title: 'OTP Sent!',
        text: '<%= success %>',
        confirmButtonColor: '#d4af37'
      });
    </script>
  <% } %>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    const emailId=document.getElementById("email")
     const er1 = document.getElementById("error1");
     const form=document.getElementById("forgotform")

      function emailValidate(){

    const emailval = emailId.value.trim();
    const emailpattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/ ;
    if (emailval === "") {
      er1.style.display = "block";
      er1.innerHTML = "Email is required";
      return false;
    } else if (!emailpattern.test(emailval)) {
      er1.style.display = "block";
      er1.innerHTML = "Invalid email format";
      return false;
    } else {
      er1.style.display = "none";
      return true;
    }
  }

form.addEventListener('submit', function(e) {
  let valid = true;

  
  if (!emailValidate()) valid = false;

    if (!valid) {
    e.preventDefault(); 
  }
});
</script>