<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Verify OTP • WRISTON</title>

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

  <!-- SweetAlert2 -->
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <style>
    :root {
      --black: #000000;
      --white: #ffffff;
      --gold: #d4af37;
      --border: #e5e5e5;
      --error: #c0392b;
      --light-bg: #f9f9f9;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Montserrat', sans-serif;
      background: var(--white);
      color: var(--black);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    .wriston-card {
      background: white;
      max-width: 500px;
      width: 100%;
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 20px 60px rgba(0,0,0,0.08);
    }

    .wriston-header {
      background: linear-gradient(rgba(0,0,0,0.75), rgba(0,0,0,0.75)),
                  url('https://img.freepik.com/premium-photo/two-luxury-watches-dark-reflective-surface-with-bokeh-background_14117-707786.jpg') center/cover no-repeat;
      color: white;
      text-align: center;
      padding: 50px 30px;
    }

    .wriston-logo-img {
      height: 70px;
      width: auto;
      margin-bottom: 20px;
    }

    .wriston-header h1 {
      font-family: 'Playfair Display', serif;
      font-size: 36px;
      font-weight: 800;
      letter-spacing: 1px;
      margin-bottom: 8px;
    }

    .wriston-header p {
      font-size: 15px;
      opacity: 0.9;
      font-weight: 500;
    }

    .form-body {
      padding: 50px 40px;
      text-align: center;
    }

    .otp-container {
      display: flex;
      justify-content: center;
      gap: 12px;
      margin: 30px 0;
    }

    .otp-input {
      width: 60px;
      height: 60px;
      text-align: center;
      font-size: 28px;
      font-weight: 600;
      border: 2px solid #ddd;
      border-radius: 12px;
      background: var(--light-bg);
      transition: all 0.3s;
    }

    .otp-input:focus {
      outline: none;
      border-color: var(--gold);
      box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.15);
      background: white;
    }

    .timer {
      font-size: 16px;
      color: #666;
      margin: 20px 0;
    }

    .resend-btn {
      background: none;
      border: none;
      color: var(--black);
      font-weight: 600;
      text-decoration: underline;
      cursor: pointer;
      font-size: 15px;
      display: none;
    }

    .resend-btn:hover {
      color: var(--gold);
    }

    .resend-btn.visible {
      display: inline;
    }

    .btn-wriston {
      width: 100%;
      padding: 18px;
      background: var(--black);
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 16px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      cursor: pointer;
      transition: all 0.3s;
      margin-top: 20px;
    }

    .btn-wriston:hover {
      background: #1a1a1a;
      transform: translateY(-2px);
    }

    .footer-text {
      margin-top: 30px;
      font-size: 14px;
      color: #666;
    }

    .footer-text a {
      color: var(--black);
      font-weight: 600;
      text-decoration: none;
    }

    .footer-text a:hover {
      color: var(--gold);
    }

    @media (max-width: 480px) {
      .wriston-header { padding: 40px 20px; }
      .wriston-header h1 { font-size: 32px; }
      .form-body { padding: 40px 30px; }
      .otp-input { width: 50px; height: 50px; font-size: 24px; }
    }
  </style>
</head>
<body>

  <div class="wriston-card">
    <div class="wriston-header">
    
      <h1>Verify OTP</h1>
      <p>Enter the 6-digit code sent to your email</p>
    </div>

    <div class="form-body">
      

      <form id="otpForm" >
        <div class="otp-container">
          <input type="text" maxlength="1" class="otp-input" >
          <input type="text" maxlength="1" class="otp-input" >
          <input type="text" maxlength="1" class="otp-input" >
          <input type="text" maxlength="1" class="otp-input" >
          <input type="text" maxlength="1" class="otp-input" >
          <input type="text" maxlength="1" class="otp-input" >
        </div>

        <input type="hidden" name="otp" id="hiddenOtp">

        <div class="timer">
          Time remaining: <span id="timer">01:00</span>
        </div>

        <button type="button" id="resndotp" class="resend-btn">Resend OTP</button>

        <button type="submit" class="btn-wriston">Verify</button>
      </form>

      <div class="footer-text">
        <a href="/forgotpass">← Back to Email</a>
      </div>
    </div>
  </div>
   
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    const inputs=document.querySelectorAll(".otp-input")
     const otpForm = document.getElementById("otpForm");
const hiddenOtp = document.getElementById("hiddenOtp");

    window.addEventListener("load", () => {
    inputs[0].focus();
  });

    inputs.forEach((input,i)=>{
     input.addEventListener("input",()=>{
        if (input.value && i < inputs.length - 1) {
        inputs[i + 1].focus();
        }
     })
      input.addEventListener("keydown", (e) => {
      if (e.key === "Backspace" && !input.value && i > 0) {
        inputs[i - 1].focus(); 
      }
    });
    })
    let timer;
    let otpExpired = false;

    

function startTimer(){
    let timeLeft=60;
    otpExpired = false;
    const t1 = document.getElementById("timer");
    document.getElementById("resndotp").style.display = "none";
    clearInterval(timer)

     timer=setInterval(()=>{
        timeLeft--;
        t1.textContent="00:"+timeLeft+"s";
        t1.style.color="green"
        


    if(timeLeft<=0){
        clearInterval(timer);
       otpExpired = true;
       Swal.fire("Expired!", "Your OTP has expired.", "error");

      document.getElementById("resndotp").style.display = "inline-block";
    }
},1000)
}




    startTimer();
   
    document.getElementById("resndotp").addEventListener("click", async (e) => {
    const btn = e.target;
      btn.disabled = true;  
     
      try {
        const response = await fetch("/resendForgotOtp", { method: "POST" });
        const data = await response.json();

        if (data.success) {
          Swal.fire("Sent!", "OTP resent successfully.", "success");
          startTimer();
        } else {
          Swal.fire("Error!", "Failed to resend OTP.", "error");
        }
      } catch (err) {
        Swal.fire("Error!", "Something went wrong.", "error");
      } finally {
    btn.disabled = false; 
  }
    });


 
otpForm.addEventListener("submit", async (e) => {
  e.preventDefault();

  let otpValue = "";
  inputs.forEach(input => otpValue += input.value);

  if (otpValue.length < inputs.length) {
    Swal.fire("Error!", "Please enter full OTP.", "error");
    return;
  }

  if (otpExpired) {
    Swal.fire("Error!", "OTP expired. Please resend.", "error");
    return;
  }

  try {
    const res = await fetch("/forgotverify", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ otp: otpValue })
    });

    const data = await res.json();

    if (!data.success) {
      
      Swal.fire("Error!", data.message || "Invalid OTP", "error");
      return;
    }

    // ✅ OTP VERIFIED
    Swal.fire({
      icon: "success",
      title: "Verified!",
      text: "OTP verified successfully",
      confirmButtonColor: "#d4af37"
    }).then(() => {
      window.location.href = "/reset-Newpass";
    });

  } catch (err) {
    Swal.fire("Error!", "Something went wrong", "error");
  }
});
 
  
 
</script>
</body>
</html>

