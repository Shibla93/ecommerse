<%- include("../../views/partials/user/header") %>

<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/assets/owl.carousel.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/assets/owl.theme.default.min.css">

<style>
  :root {
    --black: #000000;
    --gold: #d4af37;
    --white: #ffffff;
    --light-gray: #f8f8f8;
    --text: #333;
    --text-light: #999;
  }

  body { font-family: 'Montserrat', sans-serif; background: var(--white); }

  /* Hero */
  .hero { margin-top: -90px; }
  .hero__items { height: 90vh; background-size: cover; background-position: center; display: flex; align-items: center; justify-content: flex-start; }
  .hero__overlay { position: absolute; inset: 0; }
  .hero__container { max-width: 1200px; margin: 0 auto; padding: 0 40px; width: 100%; position: relative; z-index: 2; }
  .hero__text { max-width: 600px; text-align: left; }
  .hero__text h2 { font-family: 'Playfair Display', serif; font-size: 4.8rem; font-weight: 800; color: var(--gold); margin-bottom: 20px; line-height: 1.1; }
  .hero__text p { font-size: 1.3rem; color: var(--white); margin-bottom: 40px; opacity: 0.95; }
  .primary-btn { background: var(--gold); color: var(--black); padding: 16px 45px; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; border-radius: 50px; transition: all 0.4s; }
  .primary-btn:hover { background: var(--white); box-shadow: 0 10px 30px rgba(212,175,55,0.4); transform: translateY(-5px); }

  /* Categories Block */
  .banner { padding: 100px 0; background: var(--light-gray); }
  .banner-flex-row { display: flex; gap: 30px; justify-content: center; align-items: stretch; flex-wrap: wrap; }
  .banner_item { flex: 1; min-width: 300px; max-width: 400px; position: relative; overflow: hidden; border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); transition: transform 0.4s; display: flex; flex-direction: column; }
  .banner_item:hover { transform: translateY(-10px); }
  .banner_item_pic { flex-grow: 1; position: relative; }
  .banner_item_pic img { width: 100%; height: 100%; object-fit: cover; min-height: 450px; transition: transform 0.6s; }
  .banner_item:hover img { transform: scale(1.1); }
  .banner_item_text { position: absolute; bottom: 0; left: 0; right: 0; padding: 40px; text-align: center; background: linear-gradient(to top, rgba(0,0,0,0.8), transparent); }
  .banner_item_text h2 { font-family: 'Playfair Display', serif; font-size: 2.8rem; color: var(--gold); margin-bottom: 20px; text-shadow: 0 2px 10px rgba(0,0,0,0.8); }
  .banner_item_text a { background: var(--gold); color: var(--black); padding: 14px 40px; font-weight: 700; border-radius: 50px; text-transform: uppercase; letter-spacing: 1.5px; transition: all 0.3s; }
  .banner_item_text a:hover { background: var(--white); transform: scale(1.05); }

  .product {
    padding: 100px 0;
    background: var(--white);
  }

  .section-title {
    text-align: center;
    margin-bottom: 80px;
  }

  .section-title h2 {
    font-family: 'Playfair Display', serif;
    font-size: 3.2rem;
    color: var(--black);
    position: relative;
    display: inline-block;
  }

  .section-title h2::after {
    content: '';
    width: 80px;
    height: 3px;
    background: var(--gold);
    position: absolute;
    bottom: -20px;
    left: 50%;
    transform: translateX(-50%);
  }

  .new-arrivals-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    justify-content: center;
  }

  .product-card {
    width: 250px;
    background: var(--white);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    transition: all 0.4s;
    display: flex;
    flex-direction: column;
    height: 520px; /* Fixed total card height */
  }

  .product-card:hover {
    transform: translateY(-15px);
    box-shadow: 0 25px 50px rgba(0,0,0,0.15);
  }

  .product-image-wrapper {
    position: relative;
    height: 300px;
    overflow: hidden;
  }

  .product-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s;
  }

  .product-card:hover .product-image-wrapper img {
    transform: scale(1.1);
  }

  .wishlist-btn {
    position: absolute;
    top: 15px;
    right: 15px;
    background: rgba(255,255,255,0.9);
    width: 45px;
    height: 45px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #999;
    font-size: 1.3rem;
    transition: all 0.3s;
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
  }

  .wishlist-btn:hover, .wishlist-btn.active {
    color: #e74c3c;
    background: white;
  }

  .product-info {
    padding: 25px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    text-align: center;
  }

  .product-info h4 {
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 10px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-info .brand {
    font-size: 1rem;
    color: var(--text-light);
    margin-bottom: 15px;
  }

  .product-info .price {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--gold);
    margin: 15px 0;
  }

  .product-info a {
    background: var(--gold);
    color: var(--black);
    padding: 12px 30px;
    font-weight: 700;
    border-radius: 50px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    transition: all 0.3s;
    align-self: center;
  }

  .product-info a:hover {
    background: #e6c04a;
    transform: translateY(-3px);
  }
  /* Responsive */
  @media (max-width: 992px) {
    .hero__text h2 { font-size: 4rem; }
    .banner_item_pic img { min-height: 400px; }
  }
  @media (max-width: 768px) {
    .hero__items { height: 80vh; justify-content: center; }
    .hero__text { text-align: center; padding: 0 30px; }
    .hero__text h2 { font-size: 3.5rem; }
    .banner-flex-row { flex-direction: column; align-items: center; }
    .banner_item { max-width: 600px; }
    .banner_item_pic img { min-height: 350px; }
  }
  @media (max-width: 576px) {
    .hero__items { height: 70vh; }
    .hero__text h2 { font-size: 3rem; }
    .banner_item_pic img { min-height: 300px; }
  }
</style>

<!-- Hero Section (your original images kept) -->
<section class="hero">
  <div class="hero__slider owl-carousel">
    <div class="hero__items set-bg" data-setbg="/img/hero/hero-1.jpg">
      <div class="hero__overlay"></div>
      <div class="hero__container">
        <div class="hero__text">
         
          <a href="/shop" class="primary-btn">Shop Now</a>
        </div>
      </div>
    </div>
    <div class="hero__items set-bg" data-setbg="/img/hero/hero-2.jpg">
      <div class="hero__overlay"></div>
      <div class="hero__container">
        <div class="hero__text">
        
          <a href="/shop" class="primary-btn">Explore</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Categories Block (3 in one perfectly aligned row) -->
<section class="banner">
  <div class="container">
    <div class="banner-flex-row">
      <!-- Men's -->
      <div class="banner_item">
        <div class="banner_item_pic">
         <img src="/img/banner/banner-1.jpg" alt="Men Collections">
        </div>
        <div class="banner_item_text">
          <h2>MEN COLLECTIONS</h2>
          <a href="/shop">Shop now</a>
        </div>
      </div>
      <!-- Women's -->
      <div class="banner_item">
        <div class="banner_item_pic">
          <img src="/img/banner/banner-2.jpg" alt="Women Collections">
        </div>
        <div class="banner_item_text">
          <h2>WOMEN COLLECTIONS</h2>
          <a href="/shop">Shop now</a>
        </div>
      </div>
      <!-- Smart Watches -->
      <div class="banner_item">
        <div class="banner_item_pic">
         <img src="/img/banner/banner-3.jpg" alt="Smart Watches">
        </div>
        <div class="banner_item_text">
          <h2>SMART WATCHES</h2>
          <a href="/shop">Shop now</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- New Arrivals -->
 
<section class="product">
  <div class="container">
    <div class="section-title">
      <h2>New Arrivals</h2>
    </div>
    <div class="new-arrivals-grid">
      <% products.forEach(product => { %>
        <div class="product-card position-relative">
          <div class="product-image-wrapper">
            <% if (product.displayImage) { %>
              <img src="<%= product.displayImage %>" alt="<%= product.product %>">
            <% } else { %>
              <div style="height:100%;background:#f0f0f0;display:flex;align-items:center;justify-content:center;color:#999;">
                No Image
              </div>
            <% } %>
            <a href="#" class="wishlist-btn"><i class="fa fa-heart"></i></a>
          </div>
          <div class="product-info">
            <div>
              <h4><%= product.product %></h4>
              <p class="brand">Brand: <%= product.brand ? product.brand.name : 'N/A' %></p>
              <div class="price">₹<%= product.displayPrice %></div>
            </div>
            <a href="/product/<%= product._id %>">View Details</a>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<%- include("../../views/partials/user/footer.ejs") %>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/owl.carousel.min.js"></script>

<script>
  $(document).ready(function () {
    $(".hero__slider").owlCarousel({
      items: 1,
      loop: true,
      autoplay: true,
      autoplayTimeout: 5000,
      nav: true,
      dots: true,
      navText: ['<i class="fa fa-chevron-left"></i>', '<i class="fa fa-chevron-right"></i>'],
    });
  });

  document.addEventListener("DOMContentLoaded", function () {
    document.querySelectorAll(".set-bg").forEach(el => {
      const bg = el.getAttribute("data-setbg");
      if (bg) el.style.backgroundImage = `url(${bg})`;
    });

    // Wishlist (your original code)
    document.querySelectorAll(".wishlist-btn").forEach(btn => {
      btn.addEventListener("click", function (e) {
        e.preventDefault();
        this.classList.toggle("active");
        // Add your fetch code here if needed
      });
    });
  });
</script>