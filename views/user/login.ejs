<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Login • WRISTON</title>

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  


  <style>
    :root {
      --black: #000000;
      --white: #ffffff;
      --gold: #d4af37;
      --border: #e5e5e5;
      --error: #c0392b;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Montserrat', sans-serif;
      background: var(--white);
      color: var(--black);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    .wriston-card {
      background: white;
      max-width: 480px;
      width: 100%;
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 20px 60px rgba(0,0,0,0.08);
    }

    .wriston-header {
      background: 
                  url('https://thumbs.dreamstime.com/b/close-up-elegant-men-s-chronograph-watch-black-dial-gold-accents-against-dark-background-showcasing-precision-415747264.jpg') center/cover no-repeat;
      color: white;
      text-align: center;
      padding: 50px 30px;
    }

    .wriston-logo-img {
      height: 70px;
      width: auto;
      margin-bottom: 20px;
    }

    .wriston-header h1 {
      font-family: 'Playfair Display', serif;
      font-size: 36px;
      font-weight: 800;
      letter-spacing: 1px;
      margin-bottom: 8px;
    }

    .wriston-header p {
      font-size: 15px;
      opacity: 0.9;
      font-weight: 500;
    }

    .form-body {
      padding: 50px 40px;
    }

    label {
      font-weight: 600;
      font-size: 14px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #333;
      margin-bottom: 10px;
      display: block;
    }

    input {
      width: 100%;
      padding: 16px 18px;
      border: 2px solid #ddd;
      border-radius: 8px;
      font-size: 16px;
      margin-bottom: 6px;
      transition: all 0.3s;
    }

    input:focus {
      outline: none;
      border-color: var(--gold);
      box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.15);
    }

    input.error {
      border-color: var(--error);
    }

    .input-group {
      position: relative;
    }

    .toggle-password {
      position: absolute;
      right: 16px;
      top: 50%;
      transform: translateY(-50%);
      cursor: pointer;
      color: #999;
      font-size: 20px;
    }

    .toggle-password:hover { color: var(--gold); }

    .error-message {
      color: var(--error);
      font-size: 13px;
      margin-top: 4px;
      margin-bottom: 10px;
      display: none;
    }

    .btn-wriston {
      width: 100%;
      padding: 18px;
      background: var(--black);
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 16px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      cursor: pointer;
      transition: all 0.3s;
      margin-top: 20px;
    }

    .btn-wriston:hover {
      background: #1a1a1a;
      transform: translateY(-2px);
    }

    .divider {
      text-align: center;
      margin: 35px 0;
      color: #888;
      font-size: 14px;
      position: relative;
    }

    .divider::before {
      content: '';
      position: absolute;
      top: 50%;
      left: 0; right: 0;
      height: 1px;
      background: #eee;
    }

    .divider span {
      background: white;
      padding: 0 20px;
    }

    .google-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      width: 100%;
      padding: 16px;
      background: white;
      border: 2px solid #ddd;
      border-radius: 8px;
      color: #333;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.3s;
    }

    .google-btn:hover {
      border-color: var(--gold);
      background: #fdfdf9;
    }

    .footer-text {
      text-align: center;
      margin-top: 30px;
      font-size: 14px;
      color: #666;
    }

    .footer-text a {
      color: var(--black);
      font-weight: 600;
      text-decoration: none;
      margin: 0 12px;
    }

    .footer-text a:hover {
      color: var(--gold);
    }

    @media (max-width: 480px) {
      .wriston-header { padding: 40px 20px; }
      .wriston-header h1 { font-size: 32px; }
      .form-body { padding: 40px 30px; }
    }
  </style>
</head>

<body>

  <div class="wriston-card">
    <div class="wriston-header">
      <img src="/img/adminlogo (2).png" alt="WRISTON Logo" class="wriston-logo-img">
     
    </div>

    <div class="form-body">
     

      <form id="loginform" method="POST" action="/login" novalidate>
        <div>
          <label>Email Address</label>
          <input type="email" name="email" id="email" placeholder="you@example.com" value="<%= typeof email !== 'undefined' ? email : '' %>" required />
          <div id="error1" class="error-message"></div>
        </div>

        <div>
          <label>Password</label>
          <div class="input-group">
            <input type="password" name="password" id="password" placeholder="Enter your password" required />
            <i class="bi bi-eye toggle-password" id="togglePassword"></i>
          </div>
          <div id="error2" class="error-message"></div>
        </div>

        <button type="submit" class="btn-wriston">Sign In</button>
      </form>

      <div class="divider"><span>or</span></div>

      <a href="/auth/google" class="google-btn">
        <img src="https://www.google.com/favicon.ico" width="18" alt="Google">
        Continue with Google
      </a>

      <div class="footer-text">
        <a href="/forgotpass">Forgot Password?</a>
        <a href="/signup">Create Account</a>
      </div>
    </div>
  </div>

  <!-- SweetAlert for success messages -->
  <script src="https://unpkg.com/sweetalert/dist/sweetalert.min.js"></script>
<% if (typeof error !== 'undefined' && error) { %>
    <script>
      swal("Error!", "<%= error %>", "error");
    </script>
<% } %>
  <% if (typeof success !== 'undefined' && success) { %>
    <script>
      swal("Success!", "<%= success %>", "success");
    </script>
  <% } %>
  <script>
    // Toggle Password Visibility
    document.getElementById("togglePassword").addEventListener("click", function () {
      const passField = document.getElementById("password");
      const type = passField.type === "password" ? "text" : "password";
      passField.type = type;
      this.classList.toggle("bi-eye-slash", type === "password");
    });

    // Validation
    const emailEl = document.getElementById("email");
    const passEl = document.getElementById("password");
    const err1 = document.getElementById("error1");
    const err2 = document.getElementById("error2");

    const emailValidate = () => {
      const val = emailEl.value.trim();
      const regex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!val) {
        err1.textContent = "Email is required";
        err1.style.display = "block";
        return false;
      } else if (!regex.test(val)) {
        err1.textContent = "Please enter a valid email";
        err1.style.display = "block";
        return false;
      } else {
        err1.style.display = "none";
        return true;
      }
    };

    const passwordValidate = () => {
      const val = passEl.value;
      if (!val) {
        err2.textContent = "Password is required";
        err2.style.display = "block";
        return false;
      } else {
        err2.style.display = "none";
        return true;
      }
    };

    // Real-time validation
    emailEl.addEventListener("input", emailValidate);
    passEl.addEventListener("input", passwordValidate);

    // Form submit
    document.getElementById("loginform").addEventListener("submit", function(e) {
      const valid = emailValidate() && passwordValidate();
      if (!valid) e.preventDefault();
    });
  </script>
</body>
</html>