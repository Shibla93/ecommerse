<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link
    href="https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@300;400;600;700;800;900&display=swap"
    rel="stylesheet"
  />
  <link rel="stylesheet" href="css/bootstrap.min.css" type="text/css" />
  <link rel="stylesheet" href="css/style.css" type="text/css" />

    <style>
        /* body {
            font-family: Arial, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            background-color: #f4f4f4;
        } */
         body {
  font-family: Arial, sans-serif;
  display: flex;
  flex-direction: column; /* stack header, main, footer */
  min-height: 100vh;
  margin: 0;
  background-color: #f4f4f4;
}
main {
  flex: 1; 
  display: flex;
  justify-content: center; 
  align-items: center;     
  padding: 20px;           
}
footer {
  flex-shrink: 0; 
}

        .form-container {
            background-color: #fff;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
            width: 300px;
        }
        .form-container h2 {
            margin-top: 0;
            text-align: center;
        }
        .form-group {
            margin-bottom: 15px;
        }
        .form-group label {
            display: block;
            margin-bottom: 5px;
        }
        .form-group input {
            width: 100%;
            padding: 8px;
            box-sizing: border-box;
            border: 1px solid #ddd;
            border-radius: 4px;
        }
        .form-group button {
            width: 100%;
            padding: 10px;
            background-color: #000;
            color: #fff;
            border: none;
            border-radius: 4px;
            cursor: pointer;
        }
        .form-group button:hover {
            background-color: #333;
        }
        .google-btn {
            background-color: #f7f7f7;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }
        /* .google-btn:hover {
            background-color: #357abd;
        } */
        .google-btn img {
            width: 20px;
            height: 20px;
        }
        .form-links {
            text-align: center;
            font-size: 14px;
        }
        .form-links a {
            color: #4285f4;
            text-decoration: none;
            margin: 0 10px;
        }
        .form-links a:hover {
            text-decoration: underline;
        }

         .error {
      color: red;
      font-size: 12px;
      margin-top: 5px;
      display: none;
    }
    </style>
</head>

<body>
  <main>
    <div class="form-container">
        <form id="loginform" novalidate method="POST" action="/login"
>
        <div class="login-form active">
            <h2>Login</h2>
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" name="email" id="email" placeholder="Enter email" >
                <div class="error" id="error1"></div>
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" name="password" id="password" placeholder="Enter password" >
                <div class="error" id="error2"></div>
<% if (typeof error !== 'undefined' && error.length > 0) { %>
  <div class="alert alert-danger" style="text-align:center;"><%= error %></div>      
<% } %>


            <div class="form-group">
                <button type="submit">Login</button>
            </div>
            <div class="form-links">
                <a href="/forgotpass" id="forgot-password">Forgot Password?</a>
                <a href="/signup" id="sign-up">Sign Up</a>
            </div>
           


             <div class="form-group">
        <a href="/auth/google" class="google-btn">
          <img src="img/googlesignup(3).png" alt="Google Logo" width="20" height="20" />
          
        </a>
      </div>
            
        </div>
        </form>
    </div>
    </main>
    <footer>
    <%- include("../../views/partials/user/footer") %>
  </footer>
<!-- Bootstrap JS Bundle -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>


    <script>
       const form=document.getElementById("loginform")
       const emailId=document.getElementById("email")
       const passId=document.getElementById("password")
        const er1 = document.getElementById("error1");
    const er2= document.getElementById("error2");

    function emailValidate(){

    const emailval = emailId.value.trim();
    const emailpattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/ ;
    if (emailval === "") {
      er1.style.display = "block";
      er1.innerHTML = "Email is required";
      return false;
    } else if (!emailpattern.test(emailval)) {
      er1.style.display = "block";
      er1.innerHTML = "Invalid email format";
      return false;
    } else {
      er1.style.display = "none";
      return true;
    }
  }


  function passwordValidate() {
    const passval = passId.value.trim();
     const passwordRegex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[\W_]).{8,}$/;
    if (passval === "") {
      er2.style.display = "block";
      er2.innerHTML = "Password is required";
      return false;
    } else if (!passwordRegex.test(passval)) {
    er2.style.display = "block";
    er2.innerHTML =
      "Password must be at least 8 characters and include uppercase, lowercase, number, and special character";
    return false;
    } else {
      er2.style.display = "none";
      return true;
    }
  }
form.addEventListener('submit', function(e) {
  let valid = true;

  if (!passwordValidate()) valid = false;
  if (!emailValidate()) valid = false;

    if (!valid) {
    e.preventDefault(); 
  }
});
const successMsg = "<%= typeof success !== 'undefined' ? success : '' %>";
  if (successMsg) {
    Swal.fire("Success", successMsg, "success");
  }

    </script>
</body>
</html>