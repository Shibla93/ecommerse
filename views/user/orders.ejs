async function retryPayment(orderId) {
  try {
    const response = await fetch("/payment/razorpay/create-order", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ orderId })
    });

    const data = await response.json();

    if (!data.success) {
      return alert("Retry failed");
    }

    const options = {
      key: data.keyId,
      amount: data.amount,
      currency: "INR",
      order_id: data.razorpayOrderId,
      handler: async function (razorpayResponse) {
        try {
          const verifyRes = await fetch("/payment/razorpay/verify", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              razorpay_order_id: razorpayResponse.razorpay_order_id,
              razorpay_payment_id: razorpayResponse.razorpay_payment_id,
              razorpay_signature: razorpayResponse.razorpay_signature,
              orderId: data.orderId
            })
          });

          const verifyData = await verifyRes.json();

          if (verifyData.success) {
            window.location.href = verifyData.redirectUrl; // success page
          } else {
            window.location.href = verifyData.redirectUrl; // failure page
          }
        } catch (err) {
          console.error(err);
          alert("Payment verification failed");
        }
      }
    };

    const rzp = new Razorpay(options);
    rzp.open();
  } catch (err) {
    console.error(err);
    alert("Something went wrong");
  }
}

</script>