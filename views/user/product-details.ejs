<%- include("../../views/partials/user/header") %>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= product.product %> - Details</title>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  
  <style>
    :root {
      --black: #000000;
      --gold: #d4af37;
      --white: #ffffff;
      --light-gray: #f8f8f8;
      --text: #333;
      --text-light: #4b561c;
    }

    body { 
      font-family: 'Montserrat', sans-serif; 
      background: var(--white); 
      color: var(--text);
    }

    main { padding: 120px 0 80px; }

    .breadcrumbs {
      padding: 0 20px;
      margin-bottom: 30px;
      font-size: 15px;
    }

    .breadcrumbs a {
      color: var(--text-light);
      text-decoration: none;
      transition: color 0.3s;
    }

    .breadcrumbs a:hover { color: var(--gold); }

    /* Product Layout */
    .product-container {
      max-width: 1300px;
      margin: 0 auto;
      padding: 0 40px;
      display: flex;
      gap: 80px;
      flex-wrap: wrap;
    }

    /* Image Gallery */
    .images {
      flex: 1;
      min-width: 500px;
      display: flex;
      gap: 20px;
    }

    .thumbnail-slider {
      display: flex;
      flex-direction: column;
      gap: 12px;
      max-height: 520px;
      overflow-y: auto;
    }

    .thumbnail-slider::-webkit-scrollbar { width: 6px; }
    .thumbnail-slider::-webkit-scrollbar-thumb { background: #ccc; border-radius: 3px; }

    .active-thumb {
      width: 90px;
      height: 90px;
      object-fit: cover;
      border-radius: 12px;
      cursor: pointer;
      border: 3px solid transparent;
      transition: all 0.3s;
    }

    .active-thumb:hover, .active-thumb.selected {
      border-color: var(--gold);
      transform: scale(1.05);
    }

    .main-image-container {
      flex: 1;
    }

    .zoom-container {
      position: relative;
      overflow: hidden;
      width: 100%;
      height: 520px;
      border-radius: 16px;
      box-shadow: 0 15px 40px rgba(0,0,0,0.1);
    }

    .main-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }

    .main-img:hover {
      transform: scale(1.05);
    }

    /* Product Details */
    .details {
      flex: 1;
      min-width: 400px;
      max-width: 600px;
    }

    #title {
      font-family:'Times New Roman, Times, serif';
      font-size: 3rem;
      font-weight: 800;
      color: var(--black);
      margin-bottom: 20px;
      line-height: 1.2;
    }

    .details p {
      font-size: 1.1rem;
      color: var(--text-light);
      line-height: 1.7;
      margin-bottom: 30px;
    }
    .details p.in-stock {
  color: #1db340 !important;
  font-weight: 600;
}

.details p.out-of-stock {
  color: #dc3545 !important;
  font-weight: 600;
}


    .details h3 {
      font-size: 2.5rem;
      font-weight: 700;
      color: var(--gold);
      margin-bottom: 20px;
    }

    .in-stock { color: #1db340; font-weight: 600; margin-bottom: 30px; }
    .out-of-stock { color: #dc3545; font-weight: 600; margin-bottom: 30px; }

    .btn {
      background: var(--gold);
      color: var(--black);
      padding: 18px 60px;
      font-size: 1.2rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 2px;
      border: none;
      border-radius: 50px;
      cursor: pointer;
      transition: all 0.4s;
      box-shadow: 0 8px 25px rgba(212,175,55,0.3);
    }

    .btn:hover {
      background: var(--white);
      transform: translateY(-5px);
      box-shadow: 0 15px 35px rgba(212,175,55,0.4);
    }

    .btn:disabled {
      background: #ccc;
      cursor: not-allowed;
      transform: none;
    }

    /* Variant Thumbnails */
    .thumbnails {
      display: flex;
      gap: 15px;
      flex-wrap: wrap;
      margin: 40px 0;
    }

    .variant-thumb {
      width: 80px;
      height: 80px;
      object-fit: cover;
      border-radius: 12px;
      cursor: pointer;
      border: 3px solid transparent;
      transition: all 0.3s;
    }

    .variant-thumb:hover, .variant-thumb.selected {
      border-color: var(--gold);
      transform: scale(1.1);
    }

    .variant-info {
      margin-top: 20px;
      font-size: 1.1rem;
    }

    .variant-info p {
      margin-bottom: 10px;
      color: var(--text);
    }

    /* Reviews Section */
    #reviewForm {
      background: var(--light-gray);
      padding: 40px;
      border-radius: 16px;
      margin: 80px 0 50px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.05);
      max-width: 800px;
    }

    #reviewForm input, #reviewForm textarea {
      width: 100%;
      padding: 15px;
      border: 2px solid #ddd;
      border-radius: 12px;
      margin-bottom: 20px;
      font-size: 1rem;
    }

    #reviewForm input:focus, #reviewForm textarea:focus {
      border-color: var(--gold);
      outline: none;
      box-shadow: 0 0 0 4px rgba(212,175,55,0.1);
    }

    #reviewForm button {
      background: var(--gold);
      color: var(--black);
      padding: 14px 40px;
      border: none;
      border-radius: 50px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s;
    }

    #reviewForm button:hover {
      background: var(--white);
      transform: translateY(-3px);
    }

    h6 {
      font-family: 'Playfair Display', serif;
      font-size: 2.5rem;
      text-align: center;
      margin-bottom: 50px;
      color: var(--black);
    }

    #reviews {
      display: grid;
      gap: 30px;
      max-width: 800px;
      margin: 0 auto;
    }

    .review {
      background: var(--light-gray);
      padding: 30px;
      border-radius: 16px;
      box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    }

    .review p:first-child {
      font-weight: 600;
      color: var(--black);
      margin-bottom: 10px;
    }

    .review small {
      color: var(--text-light);
    }

    /* Related Products */
    .related-products {
      margin-top: 100px;
      padding-top: 60px;
      border-top: 1px solid #eee;
      max-width: 1300px;
      margin-left: auto;
      margin-right: auto;
      padding-left: 40px;
      padding-right: 40px;
    }

    .related-products h4 {
      font-family: 'Playfair Display', serif;
      font-size: 2.8rem;
      text-align: center;
      margin-bottom: 60px;
      color: var(--black);
    }

    .related-products .related-products {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 30px;
    }

    .related-card {
      background: var(--white);
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 10px 30px rgba(0,0,0,0.08);
      transition: all 0.4s;
      text-align: center;
    }

    .related-card:hover {
      transform: translateY(-10px);
    }

    .related-card img {
      width: 100%;
      height: 220px;
      object-fit: cover;
    }

    .related-card p {
      padding: 20px;
      font-size: 1.2rem;
      color: var(--text);
    }

    /* Responsive */
    @media (max-width: 992px) {
      .product-container { flex-direction: column; gap: 50px; }
      .images { min-width: auto; }
      .zoom-container, .main-img { height: 450px; }
    }

    @media (max-width: 768px) {
      .images { flex-direction: column; }
      .thumbnail-slider { flex-direction: row; overflow-x: auto; max-height: none; }
      .active-thumb { width: 80px; height: 80px; }
      .zoom-container, .main-img { height: 400px; }
      #title { font-size: 2.8rem; }
    }

    @media (max-width: 576px) {
      .zoom-container, .main-img { height: 350px; }
      #title { font-size: 2.5rem; }
    }
  </style>
</head>

<body>
<main>

  <!-- Breadcrumbs -->
  <div class="breadcrumbs container">
    <a href="/">Home</a> » <a href="/shop">Shop</a> » <%= product.product %>
  </div>

  <div class="product-container">
    <!-- LEFT: Image Gallery -->
    <div class="images">
      <div class="thumbnail-slider">
        <% activeVariant.images.forEach(img => { %>
          <img src="<%= img.croppedUrl %>" class="active-thumb" data-url="<%= img.croppedUrl %>">
        <% }) %>
      </div>

      <div class="main-image-container">
        <div class="zoom-container">
          <img id="mainImage" src="<%= activeVariant.images[0].croppedUrl %>" class="main-img" alt="Product Image">
        </div>
      </div>
    </div>

    <!-- RIGHT: Product Details -->
    <div class="details">
      <h2 id="title"><%= product.product %> <%= activeVariant.dialColor %> Dial with <%= activeVariant.strapColor %> Strap</h2>
      <p><%= product.description %></p>
      <h3>₹<%= activeVariant.price.toLocaleString('en-IN') %></h3> 

      <% if(activeVariant.stock > 0) { %>
        <p class="in-stock">In Stock (<%= activeVariant.stock %> available)</p>
        <button class="btn">Add to Cart</button>
      <% } else { %>
        <p class="out-of-stock">Sold Out</p>
        <button class="btn" onclick="notify()">Notify Me</button>
      <% } %>

      <div class="thumbnails">
        <% listedVariants.forEach((v, i) => { %>
          <% if(v.images && v.images.length > 0) { %>
            <img src="<%= v.images[0].croppedUrl %>" 
     class="variant-thumb" 
     data-variant-id="<%= v._id %>">
          <% } %>
        <% }) %>
      </div>

      <div class="variant-info">
        <p>Price: <span id="variantPrice"><%= activeVariant.price %></span></p>
        <p>Color: <span id="variantColor"><%= activeVariant.strapColor || 'N/A' %></span></p>
      </div>
    </div>
  </div>

  <!-- Reviews -->
  <div class="container">
    <form id="reviewForm">
      <input type="number" name="rating" min="1" max="5" placeholder="Your Rating (1-5)" required>
      <textarea name="comment" rows="4" placeholder="Write your review..." required></textarea>
      <button type="submit">Submit Review</button>
    </form>

    <h6>Reviews (<%= product.reviews?.length || 0 %>)</h6>
    <div id="reviews">
      <% (product.reviews || []).forEach(review => { %>
        <div class="review">
          <p><strong><%= review.name || 'Anonymous' %></strong> - <%= "⭐".repeat(review.rating) %></p>
          <p><%= review.comment %></p>
          <small><%= new Date(review.createdAt).toLocaleDateString() %></small>
        </div>
      <% }) %>
    </div>
  </div>

  <!-- Related Products -->
  <div class="related-products container">
    <h4>Related Products</h4>
    <div class="related-products">
      <% if (relatedProducts.length > 0) { %>
        <% relatedProducts.forEach(rp => { %>
          <div class="related-card">
            <a href="/product/<%= rp._id %>?variant=<%= rp.variants[0]._id %>">
              <img src="<%= rp.variants[0].images[0]?.croppedUrl || '/images/default-product.png' %>" alt="<%= rp.product %>">
              <p><%= rp.product %></p>
              <div style="font-size:1.4rem; color:var(--gold); padding-bottom:20px;">₹<%= rp.variants[0].price.toLocaleString('en-IN') %></div>
            </a>
          </div>
        <% }) %>
      <% } else { %>
        <p style="text-align:center; grid-column: 1 / -1;">No related products found.</p>
      <% } %>
    </div>
  </div>

</main>

<%- include("../../views/partials/user/footer") %>

<!-- Your original JavaScript (unchanged) -->
<script>
const mainImage = document.getElementById('mainImage');
const variants = <%- JSON.stringify(listedVariants) %>;
const priceEl = document.getElementById('variantPrice');
const colorEl = document.getElementById('variantColor');
const titleEl = document.getElementById('title');
const productData = <%- JSON.stringify(product) %>;
const activeVariantData = <%- JSON.stringify(activeVariant) %>;

// Active Thumbnail Click
document.querySelectorAll('.active-thumb').forEach(img => {
  img.addEventListener('click', () => {
    mainImage.src = img.dataset.url;
    document.querySelectorAll('.active-thumb').forEach(t => t.classList.remove('selected'));
    img.classList.add('selected');
  });
});
document.querySelectorAll('.variant-thumb').forEach(thumb => {
  thumb.addEventListener('click', function () {
    const variantId = this.dataset.variantId;
    const productId = "<%= product._id %>";

    window.location.href = `/product/${productId}?variant=${variantId}`;
  });
});


// Better Zoom Effect
const zoomContainer = document.querySelector('.zoom-container');
const zoomImage = document.getElementById('mainImage');

zoomContainer.addEventListener('mousemove', (e) => {
  const rect = zoomContainer.getBoundingClientRect();
  const x = (e.clientX - rect.left) / rect.width;
  const y = (e.clientY - rect.top) / rect.height;

  zoomImage.style.transformOrigin = `${x * 100}% ${y * 100}%`;
  zoomImage.style.transform = "scale(2.2)";
});

zoomContainer.addEventListener('mouseleave', () => {
  zoomImage.style.transformOrigin = "center center";
  zoomImage.style.transform = "scale(1)";
});

// Notify
function notify() {
  Swal.fire("We'll notify you when this item is back in stock!");
}

// Submit Review
const form = document.getElementById("reviewForm");
form.addEventListener("submit", async (e) => {
  e.preventDefault();
  const rating = form.rating.value;
  const comment = form.comment.value;
  const productId = "<%= product._id %>";

  const res = await fetch(`/product/${productId}/review`, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ rating, comment }),
  });
  const data = await res.json();
  Swal.fire(data.message);

  if(data.product) {
    const reviewsDiv = document.getElementById("reviews");
    reviewsDiv.innerHTML = "";
    const reviewsCount = data.product.reviews.length;
    document.querySelector("h6").textContent = `Reviews (${reviewsCount})`;

    data.product.reviews.forEach(review => {
      const stars = "⭐".repeat(review.rating); 
      const div = document.createElement("div");
      div.className = "review";
      div.innerHTML = `<p><strong>${review.name}</strong> - ${stars}</p>
                       <p>${review.comment}</p>
                       <small>${new Date(review.createdAt).toLocaleDateString()}</small>`;
      reviewsDiv.appendChild(div);
    });
    form.reset();
  }
});
</script>

</body>
</html>