                        </path>
                        <circle cx="12" cy="13" r="4"></circle>
                      </svg>
                    </button>


                    <input type="file" id="dp" name="profileImage" accept="image/*" style="display: none;">
                    <small id="imageError" style="color:red; display:none;"></small>


                  </div>

                  <h2 class="profile-name">
                    <%= user.name %>
                  </h2>
                </div>

                <!-- Form Fields -->

                <!-- Full Name -->
                <div class="form-group">
                  <label class="form-label">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                      stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                      <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                    Full Name
                  </label>
                  <div class="input-wrapper">
                    <input type="text" name="name" value="<%= user.name %>" readonly class="form-input">
                    <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                      viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                      stroke-linejoin="round">
                      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                      <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                  </div>
                </div>

                <!-- Email -->
                <div class="form-group">
                  <label class="form-label">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                      stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                      <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                    </svg>
                    Email Address
                  </label>
                  <div class="input-wrapper">
                    <input type="email" name="email" value="<%= user.email %>" readonly class="form-input">
