<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Profile </title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap"
    rel="stylesheet">

</head>


<style>
  /* Reset and Base Styles */
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    /* Colors */
    --color-background: #ffffff;
    --color-foreground: #1a1a1a;
    --color-muted: #6b7280;
    --color-muted-bg: #f9fafb;
    --color-border: #e5e7eb;
    --color-card: #ffffff;

    /* Watch Colors */
    --color-gold: #d4af37;
    --color-gold-hover: #c19a2e;
    --color-steel: #4b5563;
    --color-steel-hover: #374151;
    --color-bronze: #cd7f32;

    /* Typography */
    --font-serif: "Playfair Display", serif;
    --font-sans: "Inter", sans-serif;

    /* Spacing */
    --spacing-xs: 0.5rem;
    --spacing-sm: 1rem;
    --spacing-md: 1.5rem;
    --spacing-lg: 2rem;
    --spacing-xl: 3rem;
    --spacing-2xl: 4rem;
    --spacing-3xl: 5rem;

    /* Border Radius */
    --radius-sm: 0.5rem;
    --radius-md: 0.75rem;
    --radius-lg: 1rem;
    --radius-xl: 1.5rem;
    --radius-full: 9999px;

    /* Shadows */
    --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
    --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
  }

  body {
    font-family: var(--font-sans);
    background-color: var(--color-background);
    color: var(--color-foreground);
    line-height: 1.6;
    min-height: 100vh;
  }

  .container {
    min-height: 100vh;
    background-color: var(--color-background);
    display: flex;
    justify-content: center;
  }


  .content-wrapper {
    width: 100%;
    max-width: 1100px;
    padding: 3rem 2rem;
  }


  /* Page Header */
  .page-header {
    text-align: center;
    margin-bottom: var(--spacing-3xl);
  }

  .page-title {
    font-family: var(--font-serif);
    font-size: 3.5rem;
    color: var(--color-foreground);
    margin-bottom: var(--spacing-sm);
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .page-subtitle {
    color: var(--color-muted);
    font-size: 1.125rem;
  }

  /* Profile Card */
  .profile-card {
    background-color: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    margin: 0 auto;
    width: 100%;

  }

  /* Profile Avatar Section */
  .profile-avatar-section {
    padding: var(--spacing-xl);
    border-bottom: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
  }

  .form-footer {
    padding: 2rem 3rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    justify-content: center;
  }

  .form-group {
    width: 100%;
  }

  @media (max-width: 768px) {
    .profile-form {
      padding: 2rem 1.5rem;
    }

    .form-footer {
      padding: 2rem 1.5rem;
    }
  }

  .avatar-container {
    position: relative;
  }

  .avatar-wrapper {
    width: 10rem;
    height: 10rem;
    border-radius: var(--radius-full);
    overflow: hidden;
    border: 4px solid var(--color-gold);
    box-shadow: var(--shadow-lg);
    transition: transform 0.3s ease;
  }

  .avatar-wrapper:hover {
    transform: scale(1.05);
  }

  .avatar-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .avatar-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-gold), var(--color-bronze));
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 3rem;
    font-family: var(--font-serif);
  }

  .avatar-upload-btn {
    position: absolute;
    bottom: 0.5rem;
    right: 0.5rem;
    width: 3rem;
    height: 3rem;
    background-color: var(--color-gold);
    border: none;
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-lg);
    cursor: pointer;
    transition: all 0.3s ease;
    color: white;
  }

  .avatar-upload-btn:hover {
    background-color: var(--color-gold-hover);
    transform: scale(1.1);
  }

  .profile-name {
    margin-top: var(--spacing-md);
    font-family: var(--font-serif);
    font-size: 1.5rem;
    color: var(--color-foreground);
  }

  /* Profile Form */
  .profile-form {
    padding: var(--spacing-xl);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .form-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-foreground);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .form-label svg {
    color: var(--color-gold);
  }

  .input-wrapper {
    position: relative;
  }

  .form-input {
    width: 100%;
    padding: 0.75rem 1rem;
    padding-left: 3rem;
    background-color: rgba(249, 250, 251, 0.3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-foreground);
    font-size: 1rem;
    font-family: var(--font-sans);
    transition: all 0.3s ease;
  }

  .form-input:focus {
    outline: none;
    border-color: var(--color-gold);
    box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.1);
  }

  .form-input.editable {
    background-color: var(--color-background);
  }

  .input-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-muted);
  }

  .button-group {
    display: flex;
    gap: var(--spacing-sm);
    margin-top: var(--spacing-xs);
    align-items: center;
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    font-size: 1rem;
    font-weight: 500;

    font-family: var(--font-sans);
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .btn-outline {
    background-color: var(--color-foreground);
    border: 1px solid var(--color-gold);
    color: var(--color-gold);
  }

  .btn-outline:hover {
    background-color: var(--color-gold);
    color: white;
  }

  .btn-steel {
    background-color: var(--color-steel);
    color: white;
  }

  .btn-steel:hover {
    background-color: var(--color-steel-hover);
  }

  .btn-primary {
    background-color: var(--color-gold);
    color: white;
    padding: 1.25rem 3rem;
    font-size: 1.125rem;
    box-shadow: var(--shadow-lg);
  }

  .btn-primary:hover {
    background-color: var(--color-gold-hover);
    box-shadow: var(--shadow-xl);
  }

  .google-badge {
    display: flex;
    align-items: center;
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  /*  */

  /* Responsive Design */
  @media (min-width: 768px) {
    .content-wrapper {
      padding: var(--spacing-3xl) var(--spacing-md);
    }

    .page-title {
      font-size: 4rem;
    }

    .profile-avatar-section {
      padding: var(--spacing-2xl) var(--spacing-3xl);
    }

    .profile-container {
      width: 100%;
      display: flex;
      justify-content: center;
    }

    .profile-form {
      padding: var(--spacing-2xl) var(--spacing-3xl);
    }

    .form-footer {
      padding: var(--spacing-2xl) var(--spacing-3xl);
    }
  }

  .section-title {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 600;
    margin-bottom: var(--spacing-lg);
    padding-bottom: var(--spacing-sm);
    border-bottom: 2px solid var(--color-gold);
    display: inline-block;
  }

  /* Responsive adjustments */
  @media (min-width: 768px) {
    .content-wrapper {
      padding: var(--spacing-3xl) var(--spacing-md);
    }

    .page-title {
      font-size: 4rem;
    }
  }

  @media (max-width: 767px) {
    .page-title {
      font-size: 2.5rem;
    }
  }

  /* Password Card Specific */
  .password-form .form-input {
    background-color: rgba(249, 250, 251, 0.3);
  }

  .password-form .form-input.editable {
    background-color: var(--color-background);
  }

  .password-error {
    color: red;
    font-size: 0.875rem;
    margin-top: 0.25rem;
    display: none;
  }

  @media (max-width: 767px) {
    .page-title {
      font-size: 2.5rem;
    }

    .button-group {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  .input-wrapper {
    position: relative;
  }

  .toggle-password {
    position: absolute;
    top: 50%;
    right: 1rem;
    transform: translateY(-50%);
    cursor: pointer;
    color: var(--color-muted);
    font-size: 1rem;
  }

  .toggle-password:hover {
    color: var(--color-gold);
  }
</style>

<body>

  <%- include("../../views/partials/user/sidebar") %>
    <div class="main-content">
      <div class="profile-container">
        <div class="content-wrapper">
          <%- include("../../views/partials/user/header") %>
            <!-- Page Header -->
            <div class="page-header">
              <h1 class="page-title">My Profile</h1>
              <p class="page-subtitle">Manage your personal information with elegance</p>
            </div>

            <!-- Content Card -->
            <div class="profile-card">
              <form id="profileForm" class="profile-form" action="/userProfile" method="POST"
                enctype="multipart/form-data">
                <!-- Profile Avatar Section -->
                <div class="profile-avatar-section">
                  <div class="avatar-container">
                    <div class="avatar-wrapper">
                      <% if (user.hasCustomImage) { %>
                        <img src="<%= user.profileImage %>" alt="Profile" class="avatar-image">
                        <% } else { %>
                          <div class="avatar-placeholder">
                            <%= user.name.charAt(0).toUpperCase() %>
                          </div>
                          <% } %>
                    </div>

                    <!-- Upload Button -->
                    <button type="button" class="avatar-upload-btn" onclick="handleImageUpload()">
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
