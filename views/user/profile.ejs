                      stroke-linejoin="round">
                      <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                      <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                    </svg>
                  </div>
                  <div class="button-group">
                    <button type="button" class="btn btn-outline">
                      <!-- <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"></path>
                                </svg> -->
                      <a href="/change-email" class="btn btn-seconadary">
                        <i class="fas fa-edit"></i> Change Email
                      </a>
                    </button>
                  </div>
                </div>

                <!-- Phone -->
                <div class="form-group">
                  <label class="form-label">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                      stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path
                        d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z">
                      </path>
                    </svg>
                    Phone Number
                  </label>
                  <div class="input-wrapper">
                    <input type="tel" name="phone" id="phone" value="<%= user.phone %>"
                      placeholder="e.g. +91 1234567890" class="form-input editable">
                    <small id="phoneError" style="color:red; display:none;"></small>
                    <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                      viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                      stroke-linejoin="round">
                      <path
                        d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z">
                      </path>
                    </svg>
                  </div>
                </div>
               <div class="form-group">
  <label class="form-label">
    🎁 Referral Code
  </label>

  <div class="input-wrapper" style="display:flex; gap:10px;">
    
    <input 
      type="text" 
      value="<%= user.referralCode %>" 
      readonly 
      class="form-input"
      style="flex:1; font-weight:bold; letter-spacing:2px;"
    >

    <button type="button" class="btn btn-outline" onclick="copyReferral()">
      Copy
    </button>

  </div>

  <small style="color: var(--color-muted);">
    Share this code with friends & earn rewards 🎉
  </small>
</div>
<div class="form-group">
  <label>Total Rewards</label>
  <p>₹<%= user.referralRewards.length * 100 %></p>
</div>
                <!-- Password -->

                <div class="form-footer">
                  <button type="submit" form="profileForm" class="btn btn-dark">
                    Save Changes
                  </button>
                </div>


            </div>
            </form>

            <!-- Save Button -->


            <!-- Additional Info -->


            <div class="profile-card">
              <div style="padding: var(--spacing-xl); text-align: center;">
                <h2 class="section-title">Change Password</h2>
              </div>

              <% if (user.isGoogleUser) { %>
                <div style="padding: var(--spacing-xl); text-align: center;">
                  <p class="google-badge" style="font-size: 1rem; color: var(--color-muted);">Your account is linked
                    with Google. Password changes are managed through your Google account.</p>
                </div>
                <% } else { %>
                  <form id="passwordForm" class="profile-form password-form" action="/change-password" method="POST">
                    <div class="form-group">
                      <label class="form-label">Current Password</label>
                      <div class="input-wrapper">
                        <input type="password" name="currentPassword" class="form-input editable">
                        <span class="toggle-password" onclick="togglePassword('currentPassword')">
                          <i class="fas fa-eye"></i>
                        </span>
                        <small class="password-error" id="currentError"></small>
                      </div>
                    </div>

                    <div class="form-group">
                      <label class="form-label">New Password</label>
                      <div class="input-wrapper">
                        <input type="password" name="newPassword" class="form-input editable">
                        <span class="toggle-password" onclick="togglePassword('newPassword')">
                          <i class="fas fa-eye"></i>
                        </span>
                        <small class="password-error" id="newError"></small>
                      </div>
                    </div>

                    <div class="form-group">
                      <label class="form-label">Confirm New Password</label>
                      <div class="input-wrapper">
                        <input type="password" id="" name="confirmPassword" class="form-input editable">
                        <span class="toggle-password" onclick="togglePassword('confirmPassword')">
                          <i class="fas fa-eye"></i>
                        </span>
                        <small class="password-error" id="confirmError"></small>
                      </div>
                    </div>

                    <div class="form-footer">
                      <button type="submit" class="btn btn-dark">Change Password</button>
                      <a href="/forgotpass" style="margin-left: var(--spacing-md); color: var( --color-bronze);">Forgot
                        Password?</a>
                    </div>
                  </form>
                  <% } %>
                 
            
            </div>
           </div>
        </div>
      </div>
    </div>
    
  </div>
      
    
      <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>


      <script>

        function handleImageUpload() {
          document.getElementById("dp").click();
        }
        document.getElementById("dp").addEventListener("change", function (e) {
          const file = e.target.files[0];
          const error = document.getElementById("imageError");
          if (!file) return

          if (!file.type.startsWith("image/")) {
            error.innerText = "Only image files allowed";
            error.style.display = "block";
            e.target.value = "";
            return;
          }

          // Size check (2MB)
          if (file.size > 2 * 1024 * 1024) {
            error.innerText = "Image must be less than 2MB";
            error.style.display = "block";
            e.target.value = "";
            return;
          }
          error.style.display = "none";

          if (file) {
            const reader = new FileReader();
            reader.onload = function (event) {
              const avatarWrapper = document.querySelector(".avatar-wrapper");
              avatarWrapper.innerHTML = `
    <img src="${event.target.result}" class="avatar-image" />
  `;
            };

            reader.readAsDataURL(file);
          }
        });

        const phoneInput = document.getElementById("phone");
        const phoneError = document.getElementById("phoneError");

        function validatePhone() {
          const phone = phoneInput.value.trim();
          const pattern = /^[6-9]\d{9}$/;

          if (phone === "") {
            phoneError.innerText = "Phone number is required";
            phoneError.style.display = "block";
            return false;
          }

          if (!pattern.test(phone)) {
            phoneError.innerText = "Enter valid 10 digit Indian phone number";
            phoneError.style.display = "block";
            return false;
          }

          phoneError.style.display = "none";
          return true;
        }
        function togglePassword(fieldId) {
          const input = document.getElementById(fieldId);
          const icon = input.nextElementSibling.querySelector("i");

          if (input.type === "password") {
            input.type = "text";
            icon.classList.remove("fa-eye");
            icon.classList.add("fa-eye-slash");
          } else {
            input.type = "password";
            icon.classList.remove("fa-eye-slash");
            icon.classList.add("fa-eye");
          }
        }


        document.getElementById("profileForm").addEventListener("submit", function (e) {
          if (!validatePhone()) {
            e.preventDefault(); // stop submit
          }
        });
        document.getElementById("passwordForm")?.addEventListener("submit", function (e) {
          const current = document.querySelector("[name='currentPassword']").value;
          const newPass = document.querySelector("[name='newPassword']").value;
          const confirm = document.querySelector("[name='confirmPassword']").value;

          let valid = true;

          if (!current) {
            document.getElementById("currentError").textContent = "Current password is required";
            document.getElementById("currentError").style.display = "block";
            valid = false;
          }

          if (newPass.length < 8) {
            document.getElementById("newError").textContent = "New password must be at least 8 characters";
            document.getElementById("newError").style.display = "block";
            valid = false;
          }

          if (newPass !== confirm) {
            document.getElementById("confirmError").textContent = "Passwords do not match";
            document.getElementById("confirmError").style.display = "block";
            valid = false;
          }

          if (!valid) e.preventDefault();
        }); 
          <% if (typeof success !== 'undefined' && typeof message !== 'undefined') { %>
            Swal.fire({
              icon: "<%= success ? 'success' : 'error' %>",
              title: "<%= success ? 'Success' : 'Error' %>",
              text: "<%= message %>",
              confirmButtonColor: "#d4af37"
            });
  <% } %>

  
function copyReferral() {
  const code = "<%= user.referralCode %>";
  navigator.clipboard.writeText(code);

  Swal.fire({
    icon: "success",
    title: "Copied!",
    text: "Referral code copied",
    timer: 1500,
    showConfirmButton: false
  });
}

      </script>

</body>

</html>