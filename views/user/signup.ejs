<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>SIGNUP</title>

  <!-- Titan uses "Proxima Nova" – we use the closest Google Font: "Montserrat" + "Playfair Display" for luxury -->
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

  <style>
    :root {
      --black: #000000;
      --white: #ffffff;
      --gold: #d4af37;
      --light-gray: #f8f8f8;
      --border: #e5e5e5;
      --error: #c0392b;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Montserrat', sans-serif;
      background: var(--white);
      color: var(--black);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      line-height: 1.6;
    }

    .titan-card {
      background: white;
      max-width: 480px;
      width: 100%;
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 20px 60px rgba(0,0,0,0.08);
    }

    .titan-header {
      background: var(--black);
      color: white;
      text-align: center;
      padding: 50px 30px;
    }

    .titan-header h1 {
      font-family: 'Playfair Display', serif;
      font-size: 36px;
      font-weight: 800;
      letter-spacing: 1px;
      margin-bottom: 8px;
    }

    .titan-header p {
      font-size: 15px;
      opacity: 0.9;
      font-weight: 500;
    }

    .titan-logo {
      font-family: 'Playfair Display', serif;
      font-size: 42px;
      font-weight: 800;
      color: var(--gold);
      letter-spacing: 2px;
    }

    .form-body {
      padding: 50px 40px;
      background: white;
    }

    label {
      font-weight: 600;
      font-size: 14px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #333;
      margin-bottom: 10px;
      display: block;
    }

    input {
      width: 100%;
      padding: 16px 18px;
      border: 2px solid #ddd;
      border-radius: 8px;
      font-size: 16px;
      margin-bottom: 6px;
      transition: all 0.3s;
    }

    input:focus {
      outline: none;
      border-color: var(--gold);
      box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.15);
    }

    input.error {
      border-color: var(--error);
    }

    .input-group {
      position: relative;
    }

    .toggle-password {
      position: absolute;
      right: 16px;
      top: 50%;
      transform: translateY(-50%);
      cursor: pointer;
      color: #999;
      font-size: 20px;
    }

    .toggle-password:hover { color: var(--gold); }

    .error-message {
      color: var(--error);
      font-size: 13px;
      margin-top: 4px;
      margin-bottom: 10px;
      display: none;
    }

    .btn-titan {
      width: 100%;
      padding: 18px;
      background: var(--black);
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 16px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      cursor: pointer;
      transition: all 0.3s;
      margin-top: 20px;
    }

    .btn-titan:hover {
      background: #1a1a1a;
      transform: translateY(-2px);
    }

    .divider {
      text-align: center;
      margin: 35px 0;
      color: #888;
      font-size: 14px;
      position: relative;
    }

    .divider::before {
      content: '';
      position: absolute;
      top: 50%;
      left: 0; right: 0;
      height: 1px;
      background: #eee;
    }

    .divider span {
      background: white;
      padding: 0 20px;
    }

    .google-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      width: 100%;
      padding: 16px;
      background: white;
      border: 2px solid #ddd;
      border-radius: 8px;
      color: #333;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.3s;
    }

    .google-btn:hover {
      border-color: var(--gold);
      background: #fdfdf9;
    }

    .footer-text {
      text-align: center;
      margin-top: 30px;
      font-size: 14px;
      color: #666;
    }

    .footer-text a {
      color: var(--black);
      font-weight: 600;
      text-decoration: none;
    }

    .footer-text a:hover {
      color: var(--gold);
    }
    .titan-header {
  background: 
              url('https://www.shutterstock.com/image-photo/luxury-gold-watch-black-dial-260nw-1707535735.jpg') center/cover no-repeat;
  /* ↑ Best one: pure black background + shining gold watch */
  /* Alternatives:
     'https://www.shutterstock.com/image-photo/luxurious-gold-watch-reflecting-on-260nw-2707349431.jpg'
     'https://www.shutterstock.com/image-photo/luxury-gold-watch-black-dial-260nw-1707535735.jpg'
     'https://www.shutterstock.com/image-photo/closeup-luxury-man-wrist-watch-260nw-714284410.jpg'
  */
  color: white;
  text-align: center;
  padding: 50px 30px;
  position: relative;
}
.titan-logo-img {
  height: 60px; /* Adjust size as needed */
  width: auto;
  margin-bottom: 20px;
}


    @media (max-width: 480px) {
      .titan-header { padding: 40px 20px};
      .titan-header h1 { font-size: 32px; }
      .form-body { padding: 40px 30px; }
    }
  </style>
</head>
<body>

  <div class="titan-card">
    <div class="titan-header">
      <img src="/img/adminlogo (2).png" alt="WRISTON Logo" class="titan-logo-img">
      <!-- <h1>Create Account</h1>
      <p>Join the world of timeless elegance</p> -->
    </div>

    <div class="form-body">
      <form id="signupform" method="POST" action="/signup" novalidate>

        <div>
          <label>Full Name</label>
          <input type="text" id="name" name="name" placeholder="Enter the name" required />
          <div id="error1" class="error-message"></div>
        </div>

        <div>
          <label>Email Address</label>
          <input type="email" id="email" name="email" placeholder="please the enter the email" required />
          <div id="error2" class="error-message"></div>
        </div>

        <div>
          <label>Mobile Number</label>
          <input type="tel" id="phone" name="phone" placeholder="please enter the phone number" maxlength="10" required />
          <div id="error3" class="error-message"></div>
        </div>

        <div>
          <label>Password</label>
          <div class="input-group">
            <input type="password" id="password" name="password" placeholder="Create strong password" required />
            <i class="bi bi-eye toggle-password" id="togglePassword"></i>
          </div>
          <div id="error4" class="error-message"></div>
        </div>

        <div>
          <label>Confirm Password</label>
          <div class="input-group">
            <input type="password" id="cpass" name="confirmpassword" placeholder="Re-enter password" required />
            <i class="bi bi-eye toggle-password" id="toggleCPassword"></i>
          </div>
          <div id="error5" class="error-message"></div>
        </div>

        <button type="submit" class="btn-titan">Create Account</button>
      </form>

      <div class="divider"><span>or</span></div>

      <a href="/auth/google" class="google-btn">
        <img src="https://www.google.com/favicon.ico" width="18" alt="Google">
        Continue with Google
      </a>

      <div class="footer-text">
        Already have an account? <a href="/login">Sign In</a>
      </div>
    </div>
  </div>
<script src="https://unpkg.com/sweetalert/dist/sweetalert.min.js"></script>

<script>
  let nameId=document.getElementById("name");
  let emailId=document.getElementById("email");
  let phoneId=document.getElementById("phone");
  let passId=document.getElementById("password");
  let cpassId=document.getElementById("cpass");



  let er1=document.getElementById("error1");
  let er2=document.getElementById("error2");
  let er3=document.getElementById("error3");
  let er4=document.getElementById("error4");
  let er5=document.getElementById("error5");


  const togglePassword = document.getElementById("togglePassword");
  const toggleCPassword = document.getElementById("toggleCPassword");

  togglePassword.addEventListener("click", () => {
    passId.type = passId.type === "password" ? "text" : "password";
    togglePassword.classList.toggle("bi-eye-slash");
  });

  toggleCPassword.addEventListener("click", () => {
    cpassId.type = cpassId.type === "password" ? "text" : "password";
    toggleCPassword.classList.toggle("bi-eye-slash");
  });

  
  function nameValidate(){
const nameval=nameId.value.trim();
if(nameval===""){
  er1.style.display="block";
  er1.innerHTML="Name is required";
  return false
} else if (!/^[A-Za-z\s]{2,}$/.test(nameval)) {
      er1.style.display = "block";
      er1.innerHTML = "Only letters and spaces are allowed";
      return false;
    } else {
      er1.style.display = "none";
      return true;
    }
  }

  function emailValidate(){

    const emailval = emailId.value.trim();
    const emailpattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/ ;
    if (emailval === "") {
      er2.style.display = "block";
      er2.innerHTML = "Email is required";
      return false;
    } else if (!emailpattern.test(emailval)) {
      er2.style.display = "block";
      er2.innerHTML = "Invalid email format";
      return false;
    } else {
      er2.style.display = "none";
      return true;
    }
  }


  function phoneValidate(){
    let phoneval=phoneId.value.trim();
    let phonepattern= /^[6-9]\d{9}$/;
    if(phoneval===""){
      er3.style.display="block";
      er3.innerHTML="phone number is required";
      return false;
    }else if(!phonepattern.test(phoneval)){
       er3.style.display="block"
       er3.innerHTML="invalid phone number";
       return false;
    }else{
      er3.style.display="none";
      return true;
    }

  }
  
function passwordValidate() {
    const passval = passId.value.trim();
     const passwordRegex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[\W_]).{8,}$/;
    if (passval === "") {
      er4.style.display = "block";
      er4.innerHTML = "Password is required";
      return false;
    } else if (!passwordRegex.test(passval)) {
    er4.style.display = "block";
    er4.innerHTML =
      "Password must be at least 8 characters and include uppercase, lowercase, number, and special character";
    return false;
    } else {
      er4.style.display = "none";
      return true;
    }
  }

 function confirmPasswordValidate() {
  const passval = passId.value.trim();
  const cpassval = cpassId.value.trim();

  if (cpassval === "") {
    er5.style.display = "block";
    er5.innerHTML = "Please confirm your password";
    return false;
  } else if (passval !== cpassval) {
    er5.style.display = "block";
    er5.innerHTML = "Passwords do not match";
    return false;
  } else {
    er5.style.display = "none";
    return true;
  }
 }


 const form = document.getElementById('signupform');

form.addEventListener('submit', function(e) {
  let valid = true;

  if (!nameValidate()) valid = false;
  if (!emailValidate()) valid = false;
  if (!phoneValidate()) valid = false;
  if (!passwordValidate()) valid = false;
  if (!confirmPasswordValidate()) valid = false;

  if (!valid) {
    e.preventDefault(); 
  }
});


 
  nameId.addEventListener("input", nameValidate);
  emailId.addEventListener("input", emailValidate);
  phoneId.addEventListener("input", phoneValidate);
  passId.addEventListener("input", passwordValidate);
  cpassId.addEventListener("input", confirmPasswordValidate);
</script>



