<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Verify OTP • WRISTON</title>

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

  <style>
    :root {
      --black: #000000;
      --gold: #d4af37;
      --white: #ffffff;
      --border: #e5e5e5;
      --error: #c0392b;
      --light-bg: #f8f8f8;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Montserrat', sans-serif;
      background: var(--white);
      color: var(--black);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    .wriston-card {
      background: white;
      max-width: 520px;
      width: 100%;
      border: 1px solid var(--border);
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 20px 60px rgba(0,0,0,0.1);
    }

    .wriston-header {
      background: linear-gradient(rgba(0,0,0,0.75), rgba(0,0,0,0.75)),
                  url('https://img.freepik.com/premium-photo/two-luxury-watches-dark-reflective-surface-with-bokeh-background_14117-707786.jpg') center/cover no-repeat;
      color: white;
      text-align: center;
      padding: 60px 40px;
    }

    .wriston-logo-img {
      height: 70px;
      width: auto;
      margin-bottom: 20px;
    }

    .wriston-header h1 {
      font-family: 'Playfair Display', serif;
      font-size: 38px;
      font-weight: 800;
      margin-bottom: 10px;
    }

    .wriston-header p {
      font-size: 16px;
      opacity: 0.9;
    }

    .form-body {
      padding: 60px 50px;
      text-align: center;
    }

    .otp-title {
      font-size: 20px;
      font-weight: 600;
      color: #333;
      margin-bottom: 10px;
    }

    .otp-subtitle {
      font-size: 15px;
      color: #777;
      margin-bottom: 40px;
    }

    .otp-container {
      display: flex;
      justify-content: center;
      gap: 15px;
      margin-bottom: 30px;
    }

    .otp-input {
      width: 70px;
      height: 70px;
      text-align: center;
      font-size: 32px;
      font-weight: 700;
      color: var(--black);
      background: var(--light-bg);
      border: 2px solid #ddd;
      border-radius: 16px;
      transition: all 0.3s;
    }

    .otp-input:focus {
      outline: none;
      border-color: var(--gold);
      background: white;
      box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.15);
    }

    .timer-text {
      font-size: 16px;
      color: #666;
      margin-bottom: 20px;
    }

    #timer {
      font-weight: 700;
      color: var(--black);
    }

    .resend-link {
      display: none;
      color: var(--gold);
      font-weight: 600;
      font-size: 15px;
      text-decoration: underline;
      cursor: pointer;
      background: none;
      border: none;
      padding: 0;
    }

    .resend-link:hover {
      color: #b8960e;
    }

    .resend-link.visible {
      display: inline;
    }

    .btn-wriston {
      width: 100%;
      padding: 18px;
      background: var(--black);
      color: white;
      border: none;
      border-radius: 12px;
      font-size: 17px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 2px;
      cursor: pointer;
      transition: all 0.4s;
      margin-top: 30px;
    }

    .btn-wriston:hover {
      background: var(--gold);
      color: var(--black);
      transform: translateY(-5px);
      box-shadow: 0 10px 30px rgba(212,175,55,0.3);
    }

    .back-link {
      margin-top: 30px;
      font-size: 15px;
      color: #777;
    }

    .back-link a {
      color: var(--black);
      font-weight: 600;
      text-decoration: none;
    }

    .back-link a:hover {
      color: var(--gold);
    }

    @media (max-width: 480px) {
      .wriston-header { padding: 50px 30px; }
      .wriston-header h1 { font-size: 32px; }
      .form-body { padding: 50px 30px; }
      .otp-input { width: 60px; height: 60px; font-size: 28px; }
      .otp-container { gap: 10px; }
    }
  </style>
</head>
<body>

  <div class="wriston-card">
    <div class="wriston-header">
      
      <h1>Verify OTP</h1>
      <p>Enter the 6-digit code sent to your email</p>
    </div>

    <div class="form-body">
      
      <form id="otpForm" action="/verifyOtp" method="POST">
        <div class="otp-title">Enter Verification Code</div>
        <div class="otp-subtitle">We've sent a code to your registered email</div>

        <div class="otp-container">
          <input type="text" maxlength="1" class="otp-input"
       inputmode="numeric" pattern="[0-9]*">
<input type="text" maxlength="1" class="otp-input"
       inputmode="numeric" pattern="[0-9]*">
<input type="text" maxlength="1" class="otp-input"
       inputmode="numeric" pattern="[0-9]*">
<input type="text" maxlength="1" class="otp-input"
       inputmode="numeric" pattern="[0-9]*">
<input type="text" maxlength="1" class="otp-input"
       inputmode="numeric" pattern="[0-9]*">
<input type="text" maxlength="1" class="otp-input"
       inputmode="numeric" pattern="[0-9]*">

        </div>

        <input type="hidden" name="otp" id="hiddenOtp">

        <div class="timer-text">
          Time remaining: <span id="timer">01:00</span>
        </div>

        <button type="button" id="resndotp" class="resend-link">Resend OTP</button>

        <button type="submit" class="btn-wriston">Verify</button>
      </form>
   
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
<% if (typeof error !== "undefined" && error) { %>
   Swal.fire("Error", "<%= error %>", "error");
<% } %>

<% if (typeof success !== "undefined" && success) { %>
   Swal.fire("Success", "<%= success %>", "success");
<% } %>


    let inputs=document.querySelectorAll(".otp-input")
    window.addEventListener("load", () => {
    inputs[0].focus();
  });

    inputs.forEach((input,i)=>{
     input.addEventListener("input",()=>{
        if (input.value && i < inputs.length - 1) {
        inputs[i + 1].focus();
        }
     })
      input.addEventListener("keydown", (e) => {
  if (e.key === "Backspace") {
    input.value = "";
    if (i > 0) inputs[i - 1].focus();
  }
});

    })
    let timer;
    let otpExpired = false;

    
 
function startTimer() {
  let timeLeft = localStorage.getItem("otpTimeLeft");

  if (!timeLeft || timeLeft <= 0) {
    timeLeft = 120;
  }

  otpExpired = false;

  const t1 = document.getElementById("timer");
  const resendBtn = document.getElementById("resndotp");

  resendBtn.style.display = "none";
  clearInterval(timer);

  timer = setInterval(() => {
    timeLeft--;
    localStorage.setItem("otpTimeLeft", timeLeft);

    t1.textContent = "00:" + String(timeLeft).padStart(2, "0");

    if (timeLeft <= 10) {
      t1.style.color = "red";
    } else {
      t1.style.color = "green";
    }

    if (timeLeft <= 0) {
      clearInterval(timer);
      localStorage.removeItem("otpTimeLeft");
      otpExpired = true;
      resendBtn.style.display = "inline-block";
      Swal.fire("Expired!", "Your OTP has expired.", "error");
    }

  }, 1000);
}

startTimer();

    
   
    document.getElementById("resndotp").addEventListener("click", async (e) => {
    const btn = e.target;
      btn.disabled = true;  
     
      try {
        const response = await fetch("/resendOtp", { method: "POST" });
        const data = await response.json();

        if (data.success) {
          Swal.fire("Sent!", "OTP resent successfully.", "success");
             localStorage.setItem("otpTimeLeft", 60);
          startTimer();
        } else {
          Swal.fire("Error!", "Failed to resend OTP.", "error");
        }
      } catch (err) {
        Swal.fire("Error!", "Something went wrong.", "error");
      } finally {
    btn.disabled = false; 
  }
    });


  const otpForm = document.getElementById("otpForm");
const hiddenOtp = document.getElementById("hiddenOtp");

otpForm.addEventListener("submit", (e) => {
  let otpValue = "";
  inputs.forEach(input => otpValue += input.value);
  if(otpValue.length<inputs.length){
    e.preventDefault();
    Swal.fire("Error!", "Please enter full OTP.", "error");
    return
  }

  if(otpExpired) {
    e.preventDefault();
    Swal.fire("Error!", "OTP expired. Please resend.", "error");
    return;
  }
  hiddenOtp.value = otpValue;  
});
</script>

</body>
</html>



