<%- include("../../views/partials/user/header") %>
<%- include("../../views/partials/user/sidebar") %>

<style>
  :root {
    --color-gold: #d4af37;
    --color-gold-hover: #c19a2e;
    --color-dark: #1a1a1a;
    --color-muted: #6b7280;
    --color-border: #e5e7eb;
    --color-card-bg: #ffffff;
    --color-light-bg: #f9fafb;
    --radius-lg: 1rem;
    --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.1);
    --shadow-lg: 0 10px 15px -3px rgba(0,0,0,0.1);
    --danger: #ef4444;
    --success: #22c55e;
  }
.main-content {
  padding: 32px 32px 100px;     /* ← more comfortable breathing room */
  background: #f9fafb;
}

@media (max-width: 991px) {
  .main-content {
    padding: 20px 16px 80px;
  }
}

/* Center content nicely when sidebar is collapsed */
@media (min-width: 1200px) {
  .main-content .container {
    max-width: 1080px;
  }
}
  body {
    font-family: 'Montserrat', sans-serif;
    background: var(--color-light-bg);
    min-height: 100vh;
  }

  .container {
    max-width: 1100px;
    margin: 100px auto 80px;
    padding: 0 20px;
  }

  .page-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-dark);
    text-align: center;
    margin-bottom: 2.5rem;
    border-bottom: 2px solid var(--color-gold);
    display: inline-block;
    padding-bottom: 0.5rem;
  }

  .wallet-card {
    background: var(--color-card-bg);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    padding: 2.5rem;
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .balance-amount {
    font-size: 3.5rem;
    font-weight: 700;
    color: var(--color-gold);
    margin: 1rem 0;
  }

  .balance-label {
    font-size: 1.1rem;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }

  .action-buttons {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }

  .btn {
    padding: 0.9rem 2rem;
    border: none;
    border-radius: 0.75rem;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    min-width: 160px;
  }

  .btn-add {
    background: var(--color-gold);
    color: white;
  }

  .btn-withdraw {
    background: transparent;
    border: 2px solid var(--color-gold);
    color: var(--color-gold);
  }

  .btn-add:hover,
  .btn-withdraw:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .btn-withdraw:hover {
    background: var(--color-gold);
    color: white;
  }

  .transactions-section {
    background: var(--color-card-bg);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    padding: 2rem;
  }

  .section-title {
    font-size: 1.6rem;
    font-weight: 600;
    color: var(--color-dark);
    margin-bottom: 1.5rem;
    border-bottom: 2px solid var(--color-gold);
    display: inline-block;
    padding-bottom: 0.5rem;
  }

  .transaction-table {
    width: 100%;
    border-collapse: collapse;
  }

  .transaction-table th,
  .transaction-table td {
    padding: 1rem 1.2rem;
    text-align: left;
    border-bottom: 1px solid var(--color-border);
  }

  .transaction-table th {
    background: var(--color-dark);
    color: white;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.9rem;
  }

  .transaction-table tr:hover {
    background: #f8f9fa;
  }

  .transaction-type {
    font-weight: 600;
  }

  .type-credit { color: var(--success); }
  .type-debit { color: var(--danger); }

  .no-transactions {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--color-muted);
    font-size: 1.2rem;
  }

  @media (max-width: 768px) {
    .wallet-card {
      padding: 2rem;
    }
    .balance-amount {
      font-size: 2.8rem;
    }
    .action-buttons {
      flex-direction: column;
      gap: 1rem;
    }
    .transaction-table th,
    .transaction-table td {
      font-size: 0.9rem;
      padding: 0.8rem;
    }
  }
</style>

<div class="main-content">

  <div class="container">
    
    <h2 class="page-title">My Wallet</h2>

    <div class="wallet-card">
      <div class="balance-label">Available Balance</div>
      <div class="balance-amount">
        ₹<%= wallet && wallet.balance ? Number(wallet.balance).toFixed(2) : '0.00' %>
      </div>

    <!-- <div class="action-buttons">
      <button class="btn btn-add" onclick="addMoney()">Add Money</button>
      <button class="btn btn-withdraw" onclick="withdrawMoney()">Withdraw</button>
    </div>-->
  </div> 

  <div class="transactions-section">
    <h3 class="section-title">Transaction History</h3>

    <% if (transactions && transactions.length > 0) { %>
      <table class="transaction-table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Description</th>
            <th>Type</th>
            <th>Amount</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% transactions.forEach(tx => { %>
            <tr>
              <td><%= new Date(tx.createdAt).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) %></td>
              <td><%= tx.reason %></td>
              <td>
                <span class="transaction-type <%= tx.type === 'credit' ? 'type-credit' : 'type-debit' %>">
                  <%= tx.type === 'credit' ? 'Credited' : 'Debited' %>
                </span>
              </td>
              <td>
              <strong>
  <%= tx.type === 'credit' ? '+' : '-' %><%= Number(tx.amount).toFixed(2) %>
</strong>

              </td>
             
          <td>
  <span class="status-badge status-active">
    Completed
  </span>
</td>


            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } else { %>
      <div class="no-transactions">
        No transactions found in your wallet yet.
      </div>
    <% } %>
  </div>
</div>

<!-- Add Money / Withdraw Modals (example - customize as needed) -->
<div class="modal fade" id="addMoneyModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Add Money to Wallet</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <form id="addMoneyForm">
          <div class="mb-3">
            <label class="form-label">Amount (₹)</label>
            <input type="number" class="form-control" id="addAmount" min="1" required>
          </div>
          <button type="submit" class="btn btn-add w-100">Add Money</button>
        </form>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="withdrawModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Withdraw from Wallet</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <form id="withdrawForm">
          <div class="mb-3">
            <label class="form-label">Amount (₹)</label>
            <input type="number" class="form-control" id="withdrawAmount" min="1" required>
          </div>
          <button type="submit" class="btn btn-withdraw w-100">Request Withdrawal</button>
        </form>
      </div>
    </div>
  </div>
</div>
</div>
<%- include("../../views/partials/user/footer") %>

