<%- include("../partials/user/header") %>

<style>
  :root {
    --color-gold: #d4af37;
    --color-gold-hover: #c19a2e;
    --color-dark: #1a1a1a;
    --color-muted: #6b7280;
    --color-border: #e5e7eb;
    --color-card-bg: #ffffff;
    --color-light-bg: #f9fafb;
    --radius-lg: 1rem;
    --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.1);
    --shadow-lg: 0 10px 15px -3px rgba(0,0,0,0.1);
  }

  body {
    font-family: 'Montserrat', sans-serif;
    background: var(--color-light-bg);
    min-height: 100vh;
  }

  .main {
    padding: 120px 0 80px; /* Clears fixed header + space for footer */
    flex: 1;
  }

  .wishlist-container {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .page-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-dark);
    text-align: center;
    margin-bottom: 2.5rem;
    border-bottom: 2px solid var(--color-gold);
    display: inline-block;
    padding-bottom: 0.5rem;
  }

  .wishlist-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .wishlist-card {
    background: var(--color-card-bg);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .wishlist-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 30px rgba(0,0,0,0.15);
  }

  .wishlist-image {
    width: 100%;
    height: 250px;
    object-fit: cover;
  }

  .wishlist-content {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .wishlist-product-name {
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--color-dark);
    margin-bottom: 0.5rem;
  }

  .wishlist-price {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-gold);
    margin-bottom: 1rem;
  }

  .remove-btn {
    background: #dc2626;
    /* color: white;
    border: none;
    /* padding: 0.8rem 1.5rem;
    /* border-radius: 0.5rem; */
    /* padding: 0.75rem 1.4rem;
  border-radius: 0.6rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    align-self: flex-start; */ 
     color: #fff;
  border: none;
  padding: 0.75rem 1.4rem;
  border-radius: 0.6rem;
  font-weight: 600;
  cursor: pointer;
  margin-bottom: 0.6rem;
  transition: all 0.25s ease;
  box-shadow: var(--shadow-md);
  }

  .remove-btn:hover {
    background: #b91c1c;
    transform: translateY(-2px);
  }

  .empty-wishlist {
    text-align: center;
    padding: 6rem 2rem;
    background: var(--color-card-bg);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }

  .empty-wishlist h4 {
    font-size: 1.8rem;
    color: var(--color-dark);
    margin-bottom: 1rem;
  }

  .empty-wishlist p {
    color: var(--color-muted);
    margin-bottom: 2rem;
  }
  .cart-btn {
  background: var(--color-gold);
  color: #fff;
  border: none;
  padding: 0.75rem 1.4rem;
  border-radius: 0.6rem;
  font-weight: 600;
  cursor: pointer;
  margin-bottom: 0.6rem;
  transition: all 0.25s ease;
  box-shadow: var(--shadow-md);
}

.cart-btn:hover {
  background: var(--color-gold-hover);
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
}


  .shop-btn {
    background: var(--color-gold);
    color: white;
    padding: 1rem 2rem;
    border-radius: 0.75rem;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .shop-btn:hover {
    background: var(--color-gold-hover);
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }

  @media (max-width: 768px) {
    .main {
      padding: 100px 0 80px;
    }
    .wishlist-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<main class="main">
  <div class="wishlist-container">
    <h2 class="page-title">My Wishlist</h2>

    <% if (wishlist && wishlist.items.length > 0) { %>
      <div class="wishlist-grid">
        <% wishlist.items.forEach(item => { %>
         <%
  const variant = item.productId.variants.find(
    v => v._id.toString() === item.variantId.toString()
  );
%>

          <div class="wishlist-card">
            <a href="/product/<%= item.productId._id %>">
  <img src="<%= variant.images[0]?.originalUrl || '/images/placeholder.jpg' %>" 
       alt="<%= item.productId.product %>" 
       class="wishlist-image">
</a>

            <div class="wishlist-content">
              <div>
               <a href="/product/<%= item.productId._id %>" style="text-decoration:none;">
  <h4 class="wishlist-product-name"><%= item.productId.product %></h4>
</a>

                <p class="wishlist-price">₹<%= variant.price %></p>
              </div>
              <button class="cart-btn"
  onclick="moveToCart('<%= item._id %>', '<%= item.productId._id %>', '<%= item.variantId %>', 1)">
  🛒 Move to Cart
</button>


              <button class="remove-btn" onclick="removeWishlist('<%= item._id %>')">
                Remove from Wishlist
              </button>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-wishlist">
        <h4>Your Wishlist is Empty</h4>
        <p>Save your favorite watches and come back to them anytime.</p>
        <a href="/shop" class="shop-btn">Start Shopping</a>
      </div>
    <% } %>
  </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  function moveToCart(wishlistItemId, productId, variantId, quantity) {
  fetch("/wishlist/move-to-cart", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ wishlistItemId, productId, variantId, quantity })
  })
  .then(res => res.json())
  .then(data => {
    if (data.success) {
      Swal.fire({
        icon: 'success',
        title: 'Added to Cart',
        text: data.message || 'Item moved to cart successfully',
        timer: 1500,
        showConfirmButton: false
      }).then(() => {
        location.reload();
      });
    } else {
      Swal.fire({
        icon: 'error',
        title: 'Oops!',
        text: data.message || 'Something went wrong'
      });
    }
  })
  .catch(() => {
    Swal.fire('Error', 'Server error occurred', 'error');
  });
}

  function removeWishlist(wishlistItemId) {
    Swal.fire({
      title: 'Remove from Wishlist?',
      text: "This item will be removed from your wishlist.",
      icon: 'question',
      showCancelButton: true,
      confirmButtonColor: '#dc2626',
      confirmButtonText: 'Yes, remove it!'
    }).then((result) => {
      if (result.isConfirmed) {
        fetch('/wishlist/remove', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ wishlistItemId })
        })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            
            Swal.fire('Removed!', 'Item removed from wishlist.', 'success')
              .then(() => location.reload());
          } else {
            Swal.fire('Error', data.message || 'Something went wrong', 'error');
          }
        })
        .catch(() => {
          Swal.fire('Error', 'Failed to remove item', 'error');
        });
      }
    });
  }
</script>

<%- include("../partials/user/footer") %>